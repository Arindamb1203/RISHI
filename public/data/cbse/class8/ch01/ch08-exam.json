      "count": 20,
      "questions": [
        {
          "id": "cbse_8_ch08_A_001",
          "text": "The ratio 3:5 expressed as a percentage is:",
          "options": {
            "a": "35%",
            "b": "60%",
            "c": "53%",
            "d": "30%"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "3:5 means 3/5. As percentage = (3/5) × 100 = 60%."
        },
        {
          "id": "cbse_8_ch08_A_002",
          "text": "If the cost price is ₹400 and selling price is ₹460, then the profit percentage is:",
          "options": {
            "a": "10%",
            "b": "12%",
            "c": "15%",
            "d": "20%"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Profit = 460 - 400 = ₹60. Profit% = (60/400) × 100 = 15%."
        },
        {
          "id": "cbse_8_ch08_A_003",
          "text": "Simple interest on ₹1200 at 8% per annum for 2 years is:",
          "options": {
            "a": "₹172",
            "b": "₹192",
            "c": "₹204",
            "d": "₹216"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "SI = (P × R × T)/100 = (1200 × 8 × 2)/100 = 19200/100 = ₹192."
        },
        {
          "id": "cbse_8_ch08_A_004",
          "text": "A shirt marked at ₹800 is sold at 15% discount. Its selling price is:",
          "options": {
            "a": "₹620",
            "b": "₹660",
            "c": "₹680",
            "d": "₹720"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Discount = 15% of 800 = ₹120. SP = 800 - 120 = ₹680."
        },
        {
          "id": "cbse_8_ch08_A_005",
          "text": "The formula for compound interest is:",
          "options": {
            "a": "CI = P(1 + R/100)^T - P",
            "b": "CI = P × R × T / 100",
            "c": "CI = P(1 - R/100)^T",
            "d": "CI = P + PRT/100"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Amount A = P(1 + R/100)^T. Compound Interest CI = A - P = P(1 + R/100)^T - P."
        },
        {
          "id": "cbse_8_ch08_A_006",
          "text": "15% of 240 is:",
          "options": {
            "a": "24",
            "b": "30",
            "c": "36",
            "d": "40"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "15% of 240 = (15/100) × 240 = 3600/100 = 36."
        },
        {
          "id": "cbse_8_ch08_A_007",
          "text": "If loss = 20% and selling price = ₹640, the cost price is:",
          "options": {
            "a": "₹750",
            "b": "₹780",
            "c": "₹800",
            "d": "₹820"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "SP = CP × (100 - loss%)/100. 640 = CP × 80/100. CP = 640 × 100/80 = ₹800."
        },
        {
          "id": "cbse_8_ch08_A_008",
          "text": "The compound interest is always _________ the simple interest for the same principal, rate and time (more than 1 year).",
          "options": {
            "a": "equal to",
            "b": "less than",
            "c": "greater than",
            "d": "half of"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "In CI, interest is calculated on the accumulated amount (principal + previous interest), so CI > SI for time > 1 year."
        },
        {
          "id": "cbse_8_ch08_A_009",
          "text": "What is 0.05 expressed as a percentage?",
          "options": {
            "a": "0.05%",
            "b": "0.5%",
            "c": "5%",
            "d": "50%"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "0.05 = 0.05 × 100% = 5%."
        },
        {
          "id": "cbse_8_ch08_A_010",
          "text": "GST stands for:",
          "options": {
            "a": "General Sales Tax",
            "b": "Goods and Services Tax",
            "c": "Government Service Tax",
            "d": "Gross Sales Tax"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "GST = Goods and Services Tax. It is a unified indirect tax levied in India."
        },
        {
          "id": "cbse_8_ch08_A_011",
          "text": "A price increases from ₹250 to ₹300. The percentage increase is:",
          "options": {
            "a": "15%",
            "b": "18%",
            "c": "20%",
            "d": "25%"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Increase = 50. Percentage increase = (50/250) × 100 = 20%."
        },
        {
          "id": "cbse_8_ch08_A_012",
          "text": "The marked price of a fan is ₹1200. After a 10% discount, the selling price is:",
          "options": {
            "a": "₹1050",
            "b": "₹1060",
            "c": "₹1080",
            "d": "₹1100"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "kv_paper",
          "explanation": "Discount = 10% of 1200 = ₹120. SP = 1200 - 120 = ₹1080."
        },
        {
          "id": "cbse_8_ch08_A_013",
          "text": "Principal = ₹5000, Rate = 10% p.a., Time = 1 year. CI compounded annually equals:",
          "options": {
            "a": "₹400",
            "b": "₹450",
            "c": "₹500",
            "d": "₹550"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A = 5000(1 + 10/100)^1 = 5000 × 1.1 = ₹5500. CI = 5500 - 5000 = ₹500. (For 1 year, CI = SI)"
        },
        {
          "id": "cbse_8_ch08_A_014",
          "text": "A number increased by 25% becomes 75. The original number is:",
          "options": {
            "a": "55",
            "b": "60",
            "c": "65",
            "d": "70"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x × 125/100 = 75. x = 75 × 100/125 = 60."
        },
        {
          "id": "cbse_8_ch08_A_015",
          "text": "If SP = ₹540 and profit% = 8%, then cost price is:",
          "options": {
            "a": "₹480",
            "b": "₹490",
            "c": "₹500",
            "d": "₹510"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "CP = SP × 100/(100 + profit%) = 540 × 100/108 = 54000/108 = ₹500."
        },
        {
          "id": "cbse_8_ch08_A_016",
          "text": "The ratio of 50 paise to ₹3 is:",
          "options": {
            "a": "50:3",
            "b": "1:6",
            "c": "5:3",
            "d": "1:60"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "₹3 = 300 paise. Ratio = 50:300 = 1:6."
        },
        {
          "id": "cbse_8_ch08_A_017",
          "text": "When interest is compounded half-yearly at 10% per annum, the effective rate per half year is:",
          "options": {
            "a": "10%",
            "b": "20%",
            "c": "5%",
            "d": "2.5%"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "When compounded half-yearly, rate per period = Annual rate / 2 = 10/2 = 5%."
        },
        {
          "id": "cbse_8_ch08_A_018",
          "text": "Discount is always calculated on:",
          "options": {
            "a": "Cost price",
            "b": "Selling price",
            "c": "Marked price",
            "d": "Profit"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Discount is always calculated on the Marked Price (also called List Price or MRP)."
        },
        {
          "id": "cbse_8_ch08_A_019",
          "text": "If the population of a town is 50,000 and it grows at 2% per year, the population after 1 year will be:",
          "options": {
            "a": "50,500",
            "b": "51,000",
            "c": "51,500",
            "d": "52,000"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Population after 1 year = 50000 × (1 + 2/100) = 50000 × 1.02 = 51,000."
        },
        {
          "id": "cbse_8_ch08_A_020",
          "text": "Sales tax of 6% is charged on a purchase of ₹850. The total amount paid is:",
          "options": {
            "a": "₹896",
            "b": "₹901",
            "c": "₹906",
            "d": "₹910"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Tax = 6% of 850 = ₹51. Total = 850 + 51 = ₹901."
        }
      ]
    },
    "B": {
