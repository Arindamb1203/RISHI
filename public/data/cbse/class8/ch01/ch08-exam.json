      "questions": [
        {
          "id": "cbse_8_ch08_B_001",
          "text": "Ramesh buys a bicycle for ₹1800 and spends ₹200 on repairs. He sells it for ₹2200. His profit percentage is:",
          "options": {
            "a": "8%",
            "b": "10%",
            "c": "12%",
            "d": "15%"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "Total CP = 1800 + 200 = ₹2000. Profit = 2200 - 2000 = ₹200. Profit% = (200/2000) × 100 = 10%."
        },
        {
          "id": "cbse_8_ch08_B_002",
          "text": "Find the compound interest on ₹6250 at 8% per annum for 2 years, compounded annually.",
          "options": {
            "a": "₹1040",
            "b": "₹1000",
            "c": "₹1020",
            "d": "₹1060"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "A = 6250(1 + 8/100)^2 = 6250 × 1.08 × 1.08 = 6250 × 1.1664 = ₹7290. CI = 7290 - 6250 = ₹1040."
        },
        {
          "id": "cbse_8_ch08_B_003",
          "text": "A shopkeeper marks goods at 40% above cost price and allows 25% discount. His profit or loss percent is:",
          "options": {
            "a": "5% profit",
            "b": "5% loss",
            "c": "15% profit",
            "d": "15% loss"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "mp_birla",
          "explanation": "Let CP = ₹100. MP = ₹140. Discount = 25% of 140 = ₹35. SP = 140 - 35 = ₹105. Profit = 105 - 100 = ₹5 = 5%."
        },
        {
          "id": "cbse_8_ch08_B_004",
          "text": "The population of a city is 1,20,000. It increases by 5% in the first year and decreases by 5% in the second year. Population after 2 years is:",
          "options": {
            "a": "1,20,000",
            "b": "1,18,800",
            "c": "1,19,700",
            "d": "1,21,000"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "After year 1 = 120000 × 1.05 = 126000. After year 2 = 126000 × 0.95 = 119700. Wait: 126000 × 0.95 = 119700. Let me recalc: 126000 × 95/100 = 11970000/100 = 119700. Closest option is 1,19,700."
        },
        {
          "id": "cbse_8_ch08_B_005",
          "text": "A sum of money doubles itself in 10 years at simple interest. The rate of interest per annum is:",
          "options": {
            "a": "8%",
            "b": "10%",
            "c": "12%",
            "d": "15%"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "kv_paper",
          "explanation": "If P doubles, SI = P. SI = PRT/100. P = P × R × 10 / 100. 1 = R/10. R = 10%."
        },
        {
          "id": "cbse_8_ch08_B_006",
          "text": "An article is sold for ₹1170 after allowing 10% discount on marked price. The marked price is:",
          "options": {
            "a": "₹1200",
            "b": "₹1250",
            "c": "₹1300",
            "d": "₹1350"
          },
          "correct": "c",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "SP = MP × (100 - discount%)/100. 1170 = MP × 90/100. MP = 1170 × 100/90 = ₹1300."
        },
        {
          "id": "cbse_8_ch08_B_007",
          "text": "The difference between CI and SI on ₹10000 at 10% for 2 years is:",
          "options": {
            "a": "₹50",
            "b": "₹100",
            "c": "₹150",
            "d": "₹200"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert_exemplar",
          "explanation": "SI = 10000×10×2/100 = ₹2000. A(CI) = 10000×(1.1)^2 = ₹12100. CI = ₹2100. Difference = 2100 - 2000 = ₹100."
        },
        {
          "id": "cbse_8_ch08_B_008",
          "text": "In what time will ₹4000 amount to ₹4630.50 at 5% per annum compounded annually?",
          "options": {
            "a": "2 years",
            "b": "3 years",
            "c": "4 years",
            "d": "5 years"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "A = P(1+R/100)^T. 4630.50 = 4000(1.05)^T. 4630.50/4000 = 1.157625 = (1.05)^3. So T = 3 years."
        },
        {
          "id": "cbse_8_ch08_B_009",
          "text": "A TV is bought for ₹15000 and sold at a loss of 6⅔%. The selling price is:",
          "options": {
            "a": "₹13800",
            "b": "₹14000",
            "c": "₹14200",
            "d": "₹14500"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "kv_paper",
          "explanation": "Loss% = 6⅔% = 20/3%. SP = CP × (100 - 20/3)/100 = 15000 × (280/3)/100 = 15000 × 280/300 = 15000 × 14/15 = ₹14000."
        },
        {
          "id": "cbse_8_ch08_B_010",
          "text": "Meena buys a saree for ₹2400. The shopkeeper charges 12% GST. What is the total amount Meena pays?",
          "options": {
            "a": "₹2608",
            "b": "₹2688",
            "c": "₹2748",
            "d": "₹2808"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "GST = 12% of 2400 = ₹288. Total = 2400 + 288 = ₹2688."
        }
      ]
    },
