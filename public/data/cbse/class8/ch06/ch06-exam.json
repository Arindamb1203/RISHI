        {
          "id": "cbse_8_ch06_A_001",
          "text": "Which of the following is NOT a perfect square?",
          "options": { "a": "441", "b": "625", "c": "750", "d": "2025" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "750 = 2 × 3 × 5³. The primes 2 and 3 are unpaired, so 750 is not a perfect square."
        },
        {
          "id": "cbse_8_ch06_A_002",
          "text": "The square root of 225 is:",
          "options": { "a": "13", "b": "14", "c": "15", "d": "16" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "15 × 15 = 225."
        },
        {
          "id": "cbse_8_ch06_A_003",
          "text": "A perfect square number can never end in the digit:",
          "options": { "a": "0", "b": "4", "c": "8", "d": "9" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "Perfect squares end only in 0, 1, 4, 5, 6, or 9. A number ending in 8 cannot be a perfect square."
        },
        {
          "id": "cbse_8_ch06_A_004",
          "text": "The sum of first 9 odd numbers equals:",
          "options": { "a": "64", "b": "81", "c": "72", "d": "100" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "Sum of first n odd numbers = n². For n = 9: 9² = 81."
        },
        {
          "id": "cbse_8_ch06_A_005",
          "text": "How many non-perfect-square numbers lie between 7² and 8²?",
          "options": { "a": "7", "b": "8", "c": "14", "d": "15" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "Between n² and (n+1)², there are 2n non-perfect-square numbers. For n = 7: 2 × 7 = 14."
        },
        {
          "id": "cbse_8_ch06_A_006",
          "text": "√(9/25) = ?",
          "options": { "a": "9/5", "b": "3/25", "c": "3/5", "d": "9/25" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "√(9/25) = √9 / √25 = 3/5."
        },
        {
          "id": "cbse_8_ch06_A_007",
          "text": "Which of these is a Pythagorean triplet?",
          "options": { "a": "(2, 4, 5)", "b": "(6, 8, 10)", "c": "(3, 5, 7)", "d": "(4, 6, 8)" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "6² + 8² = 36 + 64 = 100 = 10². So (6, 8, 10) is a Pythagorean triplet."
        },
        {
          "id": "cbse_8_ch06_A_008",
          "text": "15² − 14² = ?",
          "options": { "a": "1", "b": "28", "c": "29", "d": "30" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "(n+1)² − n² = 2n + 1. For n = 14: 2(14) + 1 = 29."
        },
        {
          "id": "cbse_8_ch06_A_009",
          "text": "√0.0081 = ?",
          "options": { "a": "0.009", "b": "0.09", "c": "0.9", "d": "9" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "0.09 × 0.09 = 0.0081. So √0.0081 = 0.09."
        },
        {
          "id": "cbse_8_ch06_A_010",
          "text": "The square of an odd number is always:",
          "options": { "a": "Even", "b": "Divisible by 4", "c": "Odd", "d": "Prime" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "Odd × Odd = Odd. The square of any odd number is always odd."
        },
        {
          "id": "cbse_8_ch06_A_011",
          "text": "What is the least number to add to 200 to get the nearest perfect square?",
          "options": { "a": "14", "b": "24", "c": "25", "d": "36" },
          "correct": "c",
          "difficulty": "medium",
          "explanation": "14² = 196, 15² = 225. Nearest perfect square above 200 is 225. Add 225 − 200 = 25."
        },
        {
          "id": "cbse_8_ch06_A_012",
          "text": "If the area of a square field is 1156 m², its side length is:",
          "options": { "a": "32 m", "b": "36 m", "c": "38 m", "d": "34 m" },
          "correct": "d",
          "difficulty": "easy",
          "explanation": "34² = 1156. So the side is 34 m."
        },
        {
          "id": "cbse_8_ch06_A_013",
          "text": "1 + 3 + 5 + 7 + 9 + 11 = ?",
          "options": { "a": "35", "b": "36", "c": "42", "d": "49" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "Sum of first 6 odd numbers = 6² = 36."
        },
        {
          "id": "cbse_8_ch06_A_014",
          "text": "A perfect square always has an __ number of factors.",
          "options": { "a": "Even", "b": "Odd", "c": "Prime", "d": "Composite" },
          "correct": "b",
          "difficulty": "medium",
          "explanation": "Perfect squares have an odd number of factors because one factor is repeated (the square root)."
        },
        {
          "id": "cbse_8_ch06_A_015",
          "text": "√1600 = ?",
          "options": { "a": "400", "b": "4", "c": "0.4", "d": "40" },
          "correct": "d",
          "difficulty": "easy",
          "explanation": "40 × 40 = 1600. So √1600 = 40."
        },
        {
          "id": "cbse_8_ch06_A_016",
          "text": "The numbers (8, 15, 17) form a Pythagorean triplet. Which check confirms this?",
          "options": { "a": "8 + 15 = 17 × 1.35", "b": "8² + 15² = 17²", "c": "8 × 15 = 17²", "d": "8² − 15² = 17" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "64 + 225 = 289 = 17². The sum of squares of the two smaller numbers equals the square of the largest."
        },
        {
          "id": "cbse_8_ch06_A_017",
          "text": "√(4 × 2025) = ?",
          "options": { "a": "2025", "b": "90", "c": "180", "d": "45" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "√4 × √2025 = 2 × 45 = 90."
        },
        {
          "id": "cbse_8_ch06_A_018",
          "text": "Which number must be multiplied to 12 to make it a perfect square?",
          "options": { "a": "12", "b": "4", "c": "6", "d": "3" },
          "correct": "d",
          "difficulty": "medium",
          "explanation": "12 = 2² × 3. Factor 3 is unpaired. Multiply by 3 → 36 = 6²."
        },
        {
          "id": "cbse_8_ch06_A_019",
          "text": "√81 + √49 = ?",
          "options": { "a": "18", "b": "14", "c": "16", "d": "13" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "√81 = 9, √49 = 7. Sum = 9 + 7 = 16."
        },
        {
          "id": "cbse_8_ch06_A_020",
          "text": "If √x = 13/5, then x equals:",
          "options": { "a": "169/25", "b": "26/10", "c": "13/5", "d": "225/169" },
          "correct": "a",
          "difficulty": "medium",
          "explanation": "x = (13/5)² = 169/25."
        }
      ]
