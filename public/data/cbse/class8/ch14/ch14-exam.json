      "questions": [
        {
          "id": "cbse_8_ch14_A_001",
          "text": "The factorisation of 12x² + 8x is:",
          "options": {
            "a": "4(3x² + 2x)",
            "b": "4x(3x + 2)",
            "c": "2x(6x + 4)",
            "d": "8x(x + 1)"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "HCF of 12x² and 8x is 4x. 12x² + 8x = 4x(3x + 2)."
        },
        {
          "id": "cbse_8_ch14_A_002",
          "text": "Which of the following is a factor of x² - 9?",
          "options": {
            "a": "(x + 3)(x - 3)",
            "b": "(x + 9)",
            "c": "(x - 9)",
            "d": "(x + 3)²"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x² - 9 = x² - 3² = (x+3)(x-3) using the identity a²-b² = (a+b)(a-b)."
        },
        {
          "id": "cbse_8_ch14_A_003",
          "text": "The factorisation of x² + 6x + 9 is:",
          "options": {
            "a": "(x + 3)(x - 3)",
            "b": "(x + 9)(x + 1)",
            "c": "(x + 3)²",
            "d": "(x - 3)²"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x²+6x+9 = x²+2(x)(3)+3² = (x+3)²."
        },
        {
          "id": "cbse_8_ch14_A_004",
          "text": "The HCF of 18xy² and 24x²y is:",
          "options": {
            "a": "6x²y²",
            "b": "6xy",
            "c": "6xy²",
            "d": "18xy"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "HCF of 18 and 24 = 6. HCF of xy² and x²y = xy (lowest powers). So HCF = 6xy."
        },
        {
          "id": "cbse_8_ch14_A_005",
          "text": "The factorisation of 4a² - 12ab + 9b² is:",
          "options": {
            "a": "(4a - 3b)²",
            "b": "(2a + 3b)²",
            "c": "(2a - 3b)²",
            "d": "(4a + 3b)(4a - 3b)"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "4a²-12ab+9b² = (2a)²-2(2a)(3b)+(3b)² = (2a-3b)²."
        },
        {
          "id": "cbse_8_ch14_A_006",
          "text": "Factorise: x² + 5x + 6",
          "options": {
            "a": "(x + 2)(x + 3)",
            "b": "(x + 1)(x + 6)",
            "c": "(x + 6)(x - 1)",
            "d": "(x - 2)(x - 3)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "We need two numbers that multiply to 6 and add to 5: 2 and 3. So x²+5x+6 = (x+2)(x+3)."
        },
        {
          "id": "cbse_8_ch14_A_007",
          "text": "The factorisation of 6ab + 12b² is:",
          "options": {
            "a": "6b(a + 2b)",
            "b": "6ab(1 + 2b)",
            "c": "6(ab + 2b²)",
            "d": "3b(2a + 4b)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "HCF of 6ab and 12b² = 6b. 6ab + 12b² = 6b(a + 2b)."
        },
        {
          "id": "cbse_8_ch14_A_008",
          "text": "Which of the following is the correct factorisation of 25m² - 1?",
          "options": {
            "a": "(25m + 1)(25m - 1)",
            "b": "(5m + 1)(5m - 1)",
            "c": "(5m - 1)²",
            "d": "(5m + 1)²"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "25m² - 1 = (5m)² - 1² = (5m+1)(5m-1)."
        },
        {
          "id": "cbse_8_ch14_A_009",
          "text": "Factorise: 3x² - 27",
          "options": {
            "a": "3(x - 3)(x + 3)",
            "b": "3(x - 9)",
            "c": "3x(x - 9)",
            "d": "(3x - 9)(3x + 9)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "3x² - 27 = 3(x²-9) = 3(x-3)(x+3)."
        },
        {
          "id": "cbse_8_ch14_A_010",
          "text": "The factorisation of x² - 7x + 12 is:",
          "options": {
            "a": "(x - 3)(x - 4)",
            "b": "(x + 3)(x + 4)",
            "c": "(x - 3)(x + 4)",
            "d": "(x + 3)(x - 4)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Need two numbers that multiply to 12 and add to -7: -3 and -4. x²-7x+12 = (x-3)(x-4)."
        },
        {
          "id": "cbse_8_ch14_A_011",
          "text": "Factorise by regrouping: xy + xz + ay + az",
          "options": {
            "a": "(x + a)(y + z)",
            "b": "(x + y)(a + z)",
            "c": "(x + z)(y + a)",
            "d": "(xy + az)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "xy+xz+ay+az = x(y+z)+a(y+z) = (x+a)(y+z)."
        },
        {
          "id": "cbse_8_ch14_A_012",
          "text": "The factorisation of x² - x - 12 is:",
          "options": {
            "a": "(x - 4)(x + 3)",
            "b": "(x + 4)(x - 3)",
            "c": "(x - 6)(x + 2)",
            "d": "(x - 4)(x - 3)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Need two numbers that multiply to -12 and add to -1: -4 and +3. x²-x-12 = (x-4)(x+3)."
        },
        {
          "id": "cbse_8_ch14_A_013",
          "text": "Division of a polynomial by a monomial: (6x² + 9x) ÷ 3x = ?",
          "options": {
            "a": "2x + 3",
            "b": "2x + 9",
            "c": "6x + 3",
            "d": "3x + 3"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(6x²+9x) ÷ 3x = 6x²/3x + 9x/3x = 2x + 3."
        },
        {
          "id": "cbse_8_ch14_A_014",
          "text": "Factorise: 4p² + 20pq + 25q²",
          "options": {
            "a": "(2p + 5q)²",
            "b": "(2p - 5q)²",
            "c": "(4p + 5q)²",
            "d": "(2p + 25q)²"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "4p²+20pq+25q² = (2p)²+2(2p)(5q)+(5q)² = (2p+5q)²."
        },
        {
          "id": "cbse_8_ch14_A_015",
          "text": "The factorisation of x² + 2x - 15 is:",
          "options": {
            "a": "(x + 5)(x - 3)",
            "b": "(x - 5)(x + 3)",
            "c": "(x + 15)(x - 1)",
            "d": "(x - 15)(x + 1)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Need two numbers that multiply to -15 and add to +2: +5 and -3. x²+2x-15 = (x+5)(x-3)."
        },
        {
          "id": "cbse_8_ch14_A_016",
          "text": "Factorise: a² - b² - a + b",
          "options": {
            "a": "(a-b)(a+b-1)",
            "b": "(a+b)(a-b-1)",
            "c": "(a-b)²-1",
            "d": "(a-b+1)(a+b)"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert_exemplar",
          "explanation": "a²-b²-a+b = (a-b)(a+b)-(a-b) = (a-b)(a+b-1)."
        },
        {
          "id": "cbse_8_ch14_A_017",
          "text": "(8x³y²) ÷ (4xy) = ?",
          "options": {
            "a": "2x²y",
            "b": "2xy²",
            "c": "4x²y",
            "d": "2x³y"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "8x³y² ÷ 4xy = (8/4)(x³/x)(y²/y) = 2x²y."
        },
        {
          "id": "cbse_8_ch14_A_018",
          "text": "Factorise: m² - 16n²",
          "options": {
            "a": "(m - 4n)²",
            "b": "(m + 4n)²",
            "c": "(m + 4n)(m - 4n)",
            "d": "(m + 8n)(m - 2n)"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "m² - 16n² = m² - (4n)² = (m+4n)(m-4n)."
        },
        {
          "id": "cbse_8_ch14_A_019",
          "text": "Divide: (x² - 7x + 12) ÷ (x - 3)",
          "options": {
            "a": "x - 4",
            "b": "x + 4",
            "c": "x - 3",
            "d": "x + 3"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x²-7x+12 = (x-3)(x-4). Dividing by (x-3) gives (x-4)."
        },
        {
          "id": "cbse_8_ch14_A_020",
          "text": "Factorise: 2x(3x - 5) + 1(3x - 5)",
          "options": {
            "a": "(3x - 5)(2x - 1)",
            "b": "(3x - 5)(2x + 1)",
            "c": "(3x + 5)(2x + 1)",
            "d": "2x(2x + 1)"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "2x(3x-5)+1(3x-5) = (3x-5)(2x+1). Common factor is (3x-5)."
        }
      ]
    },
    "B": {
