        {
          "id": "cbse_8_ch14_B_001",
          "text": "Factorise completely: 2x³ - 8x",
          "options": {
            "a": "2x(x - 4)",
            "b": "2(x³ - 4x)",
            "c": "2x(x - 2)(x + 2)",
            "d": "2x(x² - 4)"
          },
          "correct": "c",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "2x³-8x = 2x(x²-4) = 2x(x-2)(x+2). Always factorise completely."
        },
        {
          "id": "cbse_8_ch14_B_002",
          "text": "Factorise by regrouping: 6xy - 4y + 6 - 9x",
          "options": {
            "a": "(3x - 2)(2y - 3)",
            "b": "(3x + 2)(2y - 3)",
            "c": "(3x - 2)(2y + 3)",
            "d": "(2y - 3)(3x + 2)"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "6xy-4y+6-9x = 2y(3x-2)-3(3x-2) = (3x-2)(2y-3)."
        },
        {
          "id": "cbse_8_ch14_B_003",
          "text": "Divide: (y² + 7y + 10) ÷ (y + 2)",
          "options": {
            "a": "y + 5",
            "b": "y + 3",
            "c": "y - 5",
            "d": "y + 10"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "y²+7y+10 = (y+2)(y+5). Dividing by (y+2) gives (y+5)."
        },
        {
          "id": "cbse_8_ch14_B_004",
          "text": "Factorise: 4x² - 20x + 25",
          "options": {
            "a": "(2x - 5)(2x + 5)",
            "b": "(2x + 5)²",
            "c": "(2x - 5)²",
            "d": "(4x - 5)(x - 5)"
          },
          "correct": "c",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "4x²-20x+25 = (2x)²-2(2x)(5)+5² = (2x-5)²."
        },
        {
          "id": "cbse_8_ch14_B_005",
          "text": "Find the error in factorisation: 5y(y - 2) + (y - 2) = 5y × 1 = 5y",
          "options": {
            "a": "The factorisation is correct",
            "b": "The common factor (y-2) was incorrectly removed",
            "c": "It should be (y-2)(5y+1)",
            "d": "It should be (y-2)(5y-1)"
          },
          "correct": "c",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "5y(y-2)+(y-2) = (y-2)(5y+1). The term 1 remains after factoring out (y-2). The answer 5y is wrong."
        },
        {
          "id": "cbse_8_ch14_B_006",
          "text": "Factorise: x⁴ - y⁴",
          "options": {
            "a": "(x²+y²)(x-y)(x+y)",
            "b": "(x²-y²)²",
            "c": "(x-y)⁴",
            "d": "(x²+y²)²"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "ncert_exemplar",
          "explanation": "x⁴-y⁴ = (x²)²-(y²)² = (x²+y²)(x²-y²) = (x²+y²)(x+y)(x-y)."
        },
        {
          "id": "cbse_8_ch14_B_007",
          "text": "Divide: (3x² + 11x + 6) ÷ (3x + 2)",
          "options": {
            "a": "x + 2",
            "b": "x + 3",
            "c": "x - 3",
            "d": "3x + 3"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "3x²+11x+6 = (3x+2)(x+3). Dividing by (3x+2) gives (x+3)."
        },
        {
          "id": "cbse_8_ch14_B_008",
          "text": "Factorise: a²b² - c²d²",
          "options": {
            "a": "(ab+cd)(ab-cd)",
            "b": "(ab-cd)²",
            "c": "(a²-c²)(b²-d²)",
            "d": "(ab+cd)²"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "a²b²-c²d² = (ab)²-(cd)² = (ab+cd)(ab-cd)."
        },
        {
          "id": "cbse_8_ch14_B_009",
          "text": "Factorise: 12a²b + 15ab² - 21a²b²",
          "options": {
            "a": "3ab(4a + 5b - 7ab)",
            "b": "3ab(4a + 5b + 7ab)",
            "c": "3a²b(4 + 5b - 7b)",
            "d": "ab(12a + 15b - 21ab)"
          },
          "correct": "a",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "HCF of 12a²b, 15ab², 21a²b² is 3ab. = 3ab(4a + 5b - 7ab)."
        },
        {
          "id": "cbse_8_ch14_B_010",
          "text": "Divide: (p² - 4) ÷ (p - 2)",
          "options": {
            "a": "p - 2",
            "b": "p + 2",
            "c": "p + 4",
            "d": "p² + 2"
          },
          "correct": "b",
          "difficulty": "medium",
          "source": "ncert",
          "explanation": "p²-4 = (p-2)(p+2). Dividing by (p-2) gives (p+2)."
        }
      ]
    },
