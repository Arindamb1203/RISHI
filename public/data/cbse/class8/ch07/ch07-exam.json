          "correct": "b",
          "difficulty": "medium",
          "explanation": "Unlike perfect squares, a perfect cube can end in any digit 0–9."
        },
        {
          "id": "cbse_8_ch07_A_010",
          "text": "The cube of an even number is always:",
          "options": { "a": "Odd", "b": "Prime", "c": "Even", "d": "Divisible by 9" },
