        {
          "id": "cbse_8_ch07_A_001",
          "text": "Which of the following is a perfect cube?",
          "options": { "a": "100", "b": "125", "c": "150", "d": "200" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "125 = 5³. So 125 is a perfect cube."
        },
        {
          "id": "cbse_8_ch07_A_002",
          "text": "∛216 = ?",
          "options": { "a": "4", "b": "5", "c": "6", "d": "7" },
          "correct": "c",
          "difficulty": "easy",
          "explanation": "6³ = 216. So ∛216 = 6."
        },
        {
          "id": "cbse_8_ch07_A_003",
          "text": "The cube of a negative number is always:",
          "options": { "a": "Positive", "b": "Negative", "c": "Zero", "d": "Undefined" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "Negative × Negative × Negative = Negative. The cube of any negative number is negative."
        },
        {
          "id": "cbse_8_ch07_A_004",
          "text": "∛(−512) = ?",
          "options": { "a": "8", "b": "−8", "c": "64", "d": "−64" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "(−8)³ = −512. So ∛(−512) = −8."
        },
        {
          "id": "cbse_8_ch07_A_005",
          "text": "Which of the following is NOT a perfect cube?",
