        {
          "id": "cbse_8_ch07_A_011",
          "text": "∛1000 = ?",
          "options": { "a": "10", "b": "100", "c": "31.6", "d": "50" },
          "correct": "a",
          "difficulty": "easy",
          "explanation": "10³ = 1000. So ∛1000 = 10."
        },
        {
          "id": "cbse_8_ch07_A_012",
          "text": "Which number when multiplied by 36 gives a perfect cube?",
          "options": { "a": "4", "b": "6", "c": "9", "d": "12" },
          "correct": "b",
          "difficulty": "medium",
          "explanation": "36 = 2² × 3². Need one more 2 and one more 3. Multiply by 6 → 216 = 6³."
        },
        {
          "id": "cbse_8_ch07_A_013",
          "text": "The Hardy–Ramanujan number 1729 is the smallest number expressible as the sum of two cubes in two different ways. Which of these is one such way?",
          "options": { "a": "1³ + 12³", "b": "2³ + 11³", "c": "10³ + 9³", "d": "Both a and c" },
          "correct": "d",
          "difficulty": "medium",
          "explanation": "1729 = 1³ + 12³ = 1 + 1728 = 1729, and 1729 = 9³ + 10³ = 729 + 1000 = 1729."
        },
        {
          "id": "cbse_8_ch07_A_014",
          "text": "7³ − 6³ = ?",
          "options": { "a": "37", "b": "127", "c": "91", "d": "13" },
          "correct": "b",
          "difficulty": "easy",
          "explanation": "7³ = 343, 6³ = 216. 343 − 216 = 127."
        },
        {
          "id": "cbse_8_ch07_A_015",
          "text": "∛(0.001) = ?",
