      "questions": [
        {
          "id": "cbse_8_ch09_A_001",
          "text": "The number of terms in the expression 3x² + 2xy - 5y + 7 is:",
          "options": {
            "a": "3",
            "b": "4",
            "c": "5",
            "d": "2"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "The terms are: 3x², 2xy, -5y, and 7. Total = 4 terms."
        },
        {
          "id": "cbse_8_ch09_A_002",
          "text": "The coefficient of x² in the expression -5x² + 3x - 7 is:",
          "options": {
            "a": "5",
            "b": "-5",
            "c": "3",
            "d": "-7"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "The term with x² is -5x². The coefficient (number before x²) is -5."
        },
        {
          "id": "cbse_8_ch09_A_003",
          "text": "Which of the following is a monomial?",
          "options": {
            "a": "3x + 2",
            "b": "x² - y²",
            "c": "7xy²",
            "d": "a + b + c"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A monomial has exactly one term. 7xy² is a single term, so it is a monomial."
        },
        {
          "id": "cbse_8_ch09_A_004",
          "text": "(a + b)² = ?",
          "options": {
            "a": "a² + b²",
            "b": "a² + ab + b²",
            "c": "a² + 2ab + b²",
            "d": "a² - 2ab + b²"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(a + b)² = a² + 2ab + b². This is a standard algebraic identity."
        },
        {
          "id": "cbse_8_ch09_A_005",
          "text": "(a - b)² = ?",
          "options": {
            "a": "a² + 2ab + b²",
            "b": "a² - 2ab + b²",
            "c": "a² - b²",
            "d": "a² + b²"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(a - b)² = a² - 2ab + b². The middle term is negative because of subtraction."
        },
        {
          "id": "cbse_8_ch09_A_006",
          "text": "(a + b)(a - b) = ?",
          "options": {
            "a": "a² + b²",
            "b": "a² - b²",
            "c": "a² + 2ab - b²",
            "d": "2a² - 2b²"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(a + b)(a - b) = a² - b². This is the difference of squares identity."
        },
        {
          "id": "cbse_8_ch09_A_007",
          "text": "Like terms in 3x²y + 5xy² - 2x²y + xy are:",
          "options": {
            "a": "3x²y and 5xy²",
            "b": "3x²y and -2x²y",
            "c": "5xy² and xy",
            "d": "3x²y and xy"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Like terms have the same variables raised to the same powers. 3x²y and -2x²y both have x²y, so they are like terms."
        },
        {
          "id": "cbse_8_ch09_A_008",
          "text": "The product of (2x) and (3x²) is:",
          "options": {
            "a": "5x²",
            "b": "6x²",
            "c": "6x³",
            "d": "5x³"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "2x × 3x² = (2×3)(x × x²) = 6x³."
        },
        {
          "id": "cbse_8_ch09_A_009",
          "text": "Using identity (a + b)² = a² + 2ab + b², find (x + 3)²:",
          "options": {
            "a": "x² + 3x + 9",
            "b": "x² + 6x + 9",
            "c": "x² + 9x + 6",
            "d": "x² + 9"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(x+3)² = x² + 2(x)(3) + 3² = x² + 6x + 9."
        },
        {
          "id": "cbse_8_ch09_A_010",
          "text": "The value of 99² using identity (a - b)² is:",
          "options": {
            "a": "9701",
            "b": "9801",
            "c": "9901",
            "d": "9991"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "99² = (100-1)² = 100² - 2(100)(1) + 1² = 10000 - 200 + 1 = 9801."
        },
        {
          "id": "cbse_8_ch09_A_011",
          "text": "Which expression is a binomial?",
          "options": {
            "a": "3xyz",
            "b": "4a - 3b + 2c",
            "c": "x² - y²",
            "d": "5"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A binomial has exactly two terms. x² - y² has two terms: x² and -y²."
        },
        {
          "id": "cbse_8_ch09_A_012",
          "text": "What is 3x(x + 2)?",
          "options": {
            "a": "3x² + 6",
            "b": "3x² + 6x",
            "c": "3x² + 2x",
            "d": "6x²"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "3x(x+2) = 3x·x + 3x·2 = 3x² + 6x."
        },
        {
          "id": "cbse_8_ch09_A_013",
          "text": "Using (a+b)(a-b) = a²-b², find 103 × 97:",
          "options": {
            "a": "9981",
            "b": "9991",
            "c": "10001",
            "d": "10091"
          },
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "103 × 97 = (100+3)(100-3) = 100² - 3² = 10000 - 9 = 9991."
        },
        {
          "id": "cbse_8_ch09_A_014",
          "text": "The degree of the polynomial 4x³y² + 3xy - 2 is:",
          "options": {
            "a": "2",
            "b": "3",
            "c": "4",
            "d": "5"
          },
          "correct": "d",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "Degree of 4x³y² = 3+2 = 5. Degree of 3xy = 1+1 = 2. Highest degree = 5."
        },
        {
          "id": "cbse_8_ch09_A_015",
          "text": "(x + y + z)² = x² + y² + z² + ?",
          "options": {
            "a": "xy + yz + zx",
            "b": "2xy + 2yz + 2zx",
            "c": "2(xy + yz + zx)",
            "d": "Both b and c"
          },
          "correct": "d",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(x+y+z)² = x²+y²+z²+2xy+2yz+2zx. The remaining terms = 2xy+2yz+2zx = 2(xy+yz+zx). Both b and c are correct."
        },
        {
          "id": "cbse_8_ch09_A_016",
          "text": "Add: 3x² + 2x - 5 and x² - 4x + 3. The result is:",
          "options": {
            "a": "4x² - 2x - 2",
            "b": "4x² + 6x - 2",
            "c": "4x² - 2x + 2",
            "d": "2x² - 2x - 2"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(3x²+x²) + (2x-4x) + (-5+3) = 4x² - 2x - 2."
        },
        {
          "id": "cbse_8_ch09_A_017",
          "text": "The value of (2x + 3y)² when x = 1 and y = 1 is:",
          "options": {
            "a": "15",
            "b": "20",
            "c": "25",
            "d": "30"
          },
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(2(1) + 3(1))² = (2+3)² = 5² = 25."
        },
        {
          "id": "cbse_8_ch09_A_018",
          "text": "The product (a + 3)(a + 5) using identity (x+a)(x+b) = x² + (a+b)x + ab is:",
          "options": {
            "a": "a² + 8a + 15",
            "b": "a² + 15a + 8",
            "c": "a² + 8a + 8",
            "d": "a² + 15"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(a+3)(a+5) = a² + (3+5)a + 3×5 = a² + 8a + 15."
        },
        {
          "id": "cbse_8_ch09_A_019",
          "text": "Subtract (2a - 3b) from (5a + b). The result is:",
          "options": {
            "a": "3a + 4b",
            "b": "3a - 4b",
            "c": "7a - 2b",
            "d": "3a - 2b"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(5a+b) - (2a-3b) = 5a+b-2a+3b = 3a+4b."
        },
        {
          "id": "cbse_8_ch09_A_020",
          "text": "The value of 4.7² using identity (a+b)² = a²+2ab+b² is:",
          "options": {
            "a": "22.09",
            "b": "22.09",
            "c": "21.09",
            "d": "23.09"
          },
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "4.7² = (4+0.7)² = 16 + 2(4)(0.7) + 0.49 = 16 + 5.6 + 0.49 = 22.09."
        }
      ]
    },
