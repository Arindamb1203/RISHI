      "questions": [
        {
          "id": "cbse_8_ch09_C_001",
          "text": "If a + b + c = 9 and ab + bc + ca = 26, find a² + b² + c²:",
          "options": {
            "a": "25",
            "b": "27",
            "c": "29",
            "d": "31"
          },
          "correct": "c",
          "difficulty": "hard",
          "source": "ncert_exemplar",
          "explanation": "a²+b²+c² = (a+b+c)² - 2(ab+bc+ca) = 9² - 2(26) = 81 - 52 = 29."
        },
        {
          "id": "cbse_8_ch09_C_002",
          "text": "If x + 1/x = 5, find x² + 1/x²:",
          "options": {
            "a": "21",
            "b": "23",
