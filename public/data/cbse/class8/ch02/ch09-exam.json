        {
          "id": "cbse_8_ch09_E_case1",
          "case_text": "A farmer has a square field of side x metres. He decides to extend the length by 5 m and reduce the breadth by 3 m to make a rectangular field. He wants to find the new area and compare it with the old area using algebraic identities.",
          "subparts": [
            {
              "id": "cbse_8_ch09_E_case1_q1",
              "text": "The area of the original square field is:",
              "type": "mcq",
              "options": {
                "a": "2x sq m",
                "b": "4x sq m",
                "c": "x² sq m",
                "d": "x³ sq m"
              },
              "correct": "c",
              "marks": 2,
              "explanation": "Area of square = side × side = x × x = x² sq m."
            },
            {
              "id": "cbse_8_ch09_E_case1_q2",
              "text": "The area of the new rectangular field is:",
              "type": "mcq",
              "options": {
                "a": "x² + 2x - 15 sq m",
                "b": "x² - 2x - 15 sq m",
                "c": "x² + 2x + 15 sq m",
                "d": "x² - 15 sq m"
              },
              "correct": "a",
              "marks": 2,
              "explanation": "Length = x+5, Breadth = x-3. Area = (x+5)(x-3) = x²+(-3+5)x+(5×-3) = x²+2x-15 sq m."
            },
            {
              "id": "cbse_8_ch09_E_case1_q3",
              "text": "If x = 10 m, by how many square metres is the new area less than the original? (Enter a positive number if new area is less, negative if new area is more)",
              "type": "direct_input",
              "correct_answer": "-5",
              "accepted_forms": [
                "-5",
                "5 more"
              ],
              "marks": 2,
              "explanation": "Original = 10² = 100. New = 10²+2(10)-15 = 100+20-15 = 105. New area is 5 sq m MORE than original. Answer = -5 (new is 5 more, so original is 5 less)."
            }
          ]
        },
        {
