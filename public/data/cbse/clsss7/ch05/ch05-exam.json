      "questions": [
        {
          "id": "cbse_7_ch05_A_001",
          "text": "A proper fraction is one where:",
          "options": {"a": "Numerator = Denominator", "b": "Numerator > Denominator", "c": "Numerator < Denominator", "d": "Denominator = 1"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "In a proper fraction, the numerator is less than the denominator. Its value is always less than 1."
        },
        {
          "id": "cbse_7_ch05_A_002",
          "text": "Is 7/9 a proper fraction?",
          "options": {"a": "No, because 7 is large", "b": "Yes, because 7 < 9", "c": "No, because it has no whole part", "d": "Yes, because both are odd"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "7 < 9, so the numerator is less than the denominator. Therefore 7/9 is a proper fraction."
        },
        {
          "id": "cbse_7_ch05_A_003",
          "text": "Convert 3 2/5 to an improper fraction:",
          "options": {"a": "35/5", "b": "17/5", "c": "32/5", "d": "15/5"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "3 x 5 + 2 = 15 + 2 = 17. Denominator stays 5. Answer: 17/5."
        },
        {
          "id": "cbse_7_ch05_A_004",
          "text": "Convert 11/4 to a mixed number:",
          "options": {"a": "3 1/4", "b": "2 3/4", "c": "2 1/4", "d": "1 7/4"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "11 / 4 = 2 remainder 3. So 11/4 = 2 and 3/4."
        },
        {
          "id": "cbse_7_ch05_A_005",
          "text": "Which is an equivalent fraction of 2/3?",
          "options": {"a": "3/4", "b": "4/6", "c": "5/8", "d": "6/10"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "2/3 x (2/2) = 4/6. Both numerator and denominator multiplied by 2. So 4/6 is equivalent to 2/3."
        },
        {
          "id": "cbse_7_ch05_A_006",
          "text": "Are 2/3 and 8/12 equivalent fractions?",
          "options": {"a": "No, different numerators", "b": "Yes, 8/12 simplifies to 2/3", "c": "No, different denominators", "d": "Cannot determine"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "8/12: HCF(8,12)=4. 8/4=2, 12/4=3. Simplified: 2/3. Yes, equivalent."
        },
        {
          "id": "cbse_7_ch05_A_007",
          "text": "Which is greater: 3/4 or 5/6?",
          "options": {"a": "3/4", "b": "5/6", "c": "Both are equal", "d": "Cannot compare"},
          "correct": "b",
          "difficulty": "medium",
          "explanation": "LCM(4,6)=12. 3/4=9/12. 5/6=10/12. Since 10>9, 5/6 > 3/4."
        },
        {
          "id": "cbse_7_ch05_A_008",
          "text": "1/3 + 1/4 = ?",
          "options": {"a": "2/7", "b": "1/6", "c": "7/12", "d": "2/12"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "LCM(3,4)=12. 1/3=4/12. 1/4=3/12. Sum=7/12."
        },
        {
          "id": "cbse_7_ch05_A_009",
          "text": "3/4 x 2/9 in simplest form is:",
          "options": {"a": "6/36", "b": "5/13", "c": "1/6", "d": "3/18"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "3x2=6, 4x9=36. Result=6/36. HCF(6,36)=6. Simplified: 1/6."
        },
        {
          "id": "cbse_7_ch05_A_010",
          "text": "To divide a fraction by another fraction, we:",
          "options": {"a": "Divide numerators and denominators separately", "b": "Multiply by the reciprocal of the divisor", "c": "Add the fractions and then divide by 2", "d": "Subtract the fractions"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "a/b divided by c/d = a/b x d/c (multiply by the reciprocal of the divisor)."
        },
        {
          "id": "cbse_7_ch05_A_011",
          "text": "2/3 divided by 4/5 = ?",
          "options": {"a": "8/15", "b": "10/12", "c": "5/6", "d": "6/20"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "2/3 x 5/4 = 10/12 = 5/6."
        },
        {
          "id": "cbse_7_ch05_A_012",
          "text": "Riya ate 2/5 of a pizza. The fraction remaining is:",
          "options": {"a": "2/5", "b": "3/5", "c": "1/5", "d": "4/5"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "Remaining = 1 - 2/5 = 5/5 - 2/5 = 3/5."
        },
        {
          "id": "cbse_7_ch05_A_013",
          "text": "Which is greater: 4/7 or 5/9?",
          "options": {"a": "5/9", "b": "4/7", "c": "Both equal", "d": "Cannot compare"},
          "correct": "b",
          "difficulty": "medium",
          "explanation": "Cross multiply: 4x9=36 and 5x7=35. Since 36>35, 4/7>5/9."
        },
        {
          "id": "cbse_7_ch05_A_014",
          "text": "2/5 + 3/10 = ?",
          "options": {"a": "5/15", "b": "5/10", "c": "7/10", "d": "6/10"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "LCM(5,10)=10. 2/5=4/10. 4/10 + 3/10 = 7/10."
        },
        {
          "id": "cbse_7_ch05_A_015",
          "text": "1/2 - 1/6 = ?",
          "options": {"a": "0", "b": "1/4", "c": "1/3", "d": "2/6"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "LCM(2,6)=6. 1/2=3/6. 3/6-1/6=2/6=1/3."
        },
        {
          "id": "cbse_7_ch05_A_016",
          "text": "The reciprocal of 3/7 is:",
          "options": {"a": "3/7", "b": "7/3", "c": "1/3", "d": "7"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "The reciprocal of a fraction is obtained by flipping it. Reciprocal of 3/7 = 7/3."
        },
        {
          "id": "cbse_7_ch05_A_017",
          "text": "For unit fractions (1/n), which fraction is smallest?",
          "options": {"a": "1/2", "b": "1/3", "c": "1/4", "d": "1/6"},
          "correct": "d",
          "difficulty": "medium",
          "explanation": "For unit fractions 1/n, larger denominator means smaller fraction. 1/6 has the largest denominator so it is smallest."
        },
        {
          "id": "cbse_7_ch05_A_018",
          "text": "3/7 of 49 = ?",
          "options": {"a": "14", "b": "21", "c": "28", "d": "7"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "3/7 x 49 = 3 x (49/7) = 3 x 7 = 21."
        },
        {
          "id": "cbse_7_ch05_A_019",
          "text": "5 2/3 as an improper fraction is:",
          "options": {"a": "52/3", "b": "16/3", "c": "17/3", "d": "15/3"},
          "correct": "c",
          "difficulty": "easy",
          "explanation": "5 x 3 + 2 = 15 + 2 = 17. Answer: 17/3."
        },
        {
          "id": "cbse_7_ch05_A_020",
          "text": "A tank is 5/8 full. After adding water it becomes 7/8 full. Fraction added:",
          "options": {"a": "12/8", "b": "2/8 = 1/4", "c": "1/8", "d": "3/8"},
          "correct": "b",
          "difficulty": "easy",
          "explanation": "Fraction added = 7/8 - 5/8 = 2/8 = 1/4."
        }
      ]
    },
