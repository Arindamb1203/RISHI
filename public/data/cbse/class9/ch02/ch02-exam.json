        {
          "id": "cbse_9_ch02_A_001",
          "text": "Which of the following is a polynomial?",
          "options": {"a": "x + 1/x", "b": "x^(1/2) + 1", "c": "x^2 + 2x + 1", "d": "x^(-1) + 2"},
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A polynomial has non-negative integer exponents only. x^2 + 2x + 1 satisfies this condition."
        },
        {
          "id": "cbse_9_ch02_A_002",
          "text": "The degree of the polynomial 5x^3 - 4x^2 + 7x - 2 is:",
          "options": {"a": "2", "b": "3", "c": "4", "d": "1"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "The degree is the highest power of the variable. The highest power here is 3."
        },
        {
          "id": "cbse_9_ch02_A_003",
          "text": "A polynomial of degree 1 is called:",
          "options": {"a": "constant", "b": "linear", "c": "quadratic", "d": "cubic"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A degree-1 polynomial like 2x + 3 is called a linear polynomial."
        },
        {
          "id": "cbse_9_ch02_A_004",
          "text": "The zero of the polynomial p(x) = x - 5 is:",
          "options": {"a": "-5", "b": "5", "c": "0", "d": "1/5"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "p(5) = 5 - 5 = 0. So x = 5 is the zero."
        },
        {
          "id": "cbse_9_ch02_A_005",
          "text": "Which of the following is a quadratic polynomial?",
          "options": {"a": "x^3 + 1", "b": "x + 1", "c": "x^2 - 1", "d": "5"},
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x^2 - 1 has degree 2, so it is a quadratic polynomial."
        },
        {
          "id": "cbse_9_ch02_A_006",
          "text": "The degree of a non-zero constant polynomial is:",
          "options": {"a": "0", "b": "1", "c": "not defined", "d": "-1"},
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A non-zero constant like 5 can be written as 5x^0, so its degree is 0."
        },
        {
          "id": "cbse_9_ch02_A_007",
          "text": "The number of zeroes of p(x) = (x-1)(x-2)(x-3) is:",
          "options": {"a": "1", "b": "2", "c": "3", "d": "0"},
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "p(1) = 0, p(2) = 0, p(3) = 0. So there are 3 zeroes: 1, 2, 3."
        },
        {
          "id": "cbse_9_ch02_A_008",
          "text": "If p(x) = x^2 - 4, then p(2) = ?",
          "options": {"a": "0", "b": "4", "c": "-4", "d": "8"},
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "p(2) = (2)^2 - 4 = 4 - 4 = 0."
        },
        {
          "id": "cbse_9_ch02_A_009",
          "text": "The value of p(0) for p(x) = 5x^2 - 3x + 7 is:",
          "options": {"a": "5", "b": "-3", "c": "7", "d": "9"},
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "p(0) = 5(0) - 3(0) + 7 = 7."
        },
        {
          "id": "cbse_9_ch02_A_010",
          "text": "The expansion of (x + y)^2 is:",
          "options": {"a": "x^2 + y^2", "b": "x^2 - 2xy + y^2", "c": "x^2 + 2xy + y^2", "d": "x^2 + xy + y^2"},
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(x+y)^2 = x^2 + 2xy + y^2 is the standard algebraic identity."
        },
        {
          "id": "cbse_9_ch02_A_011",
          "text": "If x + 2 is a factor of p(x) = x^2 + kx + 6, then k = ?",
          "options": {"a": "3", "b": "5", "c": "-5", "d": "-3"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "p(-2) = 0: 4 - 2k + 6 = 0, so 2k = 10, k = 5."
        },
        {
          "id": "cbse_9_ch02_A_012",
          "text": "The remainder when p(x) = x^3 + x^2 + x + 1 is divided by (x - 1) is:",
          "options": {"a": "0", "b": "2", "c": "3", "d": "4"},
          "correct": "d",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "By Remainder Theorem: p(1) = 1 + 1 + 1 + 1 = 4."
        },
        {
          "id": "cbse_9_ch02_A_013",
          "text": "The value of (99)^2 using the identity (a - b)^2 = a^2 - 2ab + b^2 is:",
          "options": {"a": "9801", "b": "9900", "c": "9800", "d": "9701"},
          "correct": "a",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "(100 - 1)^2 = 10000 - 200 + 1 = 9801."
        },
        {
          "id": "cbse_9_ch02_A_014",
          "text": "Factorisation of x^2 - 9 is:",
          "options": {"a": "(x - 3)^2", "b": "(x + 3)(x - 3)", "c": "(x - 3)(x - 3)", "d": "(x + 9)(x - 1)"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x^2 - 9 = x^2 - 3^2 = (x+3)(x-3) using a^2 - b^2 identity."
        },
        {
          "id": "cbse_9_ch02_A_015",
          "text": "One of the factors of x^3 - 8 is:",
          "options": {"a": "(x + 2)", "b": "(x - 2)", "c": "(x^2 - 4)", "d": "(x + 4)"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x^3 - 8 = x^3 - 2^3 = (x - 2)(x^2 + 2x + 4). So (x - 2) is a factor."
        },
        {
          "id": "cbse_9_ch02_A_016",
          "text": "If a + b + c = 0, then a^3 + b^3 + c^3 = ?",
          "options": {"a": "0", "b": "3abc", "c": "abc", "d": "3(a+b+c)"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "When a+b+c=0, the identity gives a^3+b^3+c^3 = 3abc."
        },
        {
          "id": "cbse_9_ch02_A_017",
          "text": "The Factor Theorem states that (x - a) is a factor of p(x) if:",
          "options": {"a": "p(1) = 0", "b": "p(a) = 0", "c": "p(-a) = 0", "d": "p(0) = 0"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "By the Factor Theorem, (x - a) is a factor of p(x) if and only if p(a) = 0."
        },
        {
          "id": "cbse_9_ch02_A_018",
          "text": "Which of the following is a factor of x^3 + y^3?",
          "options": {"a": "(x - y)", "b": "(x + y)", "c": "(x^2 - xy + y^2)", "d": "(x^2 + y^2)"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "x^3 + y^3 = (x + y)(x^2 - xy + y^2). So (x + y) is a factor."
        },
        {
          "id": "cbse_9_ch02_A_019",
          "text": "The degree of the zero polynomial is:",
          "options": {"a": "0", "b": "1", "c": "not defined", "d": "-1"},
          "correct": "c",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "The degree of the zero polynomial (p(x) = 0) is not defined."
        },
        {
          "id": "cbse_9_ch02_A_020",
          "text": "How many zeroes can a quadratic polynomial have at most?",
          "options": {"a": "1", "b": "2", "c": "3", "d": "0"},
          "correct": "b",
          "difficulty": "easy",
          "source": "ncert",
          "explanation": "A polynomial of degree n has at most n zeroes. A quadratic has degree 2, so at most 2 zeroes."
        }
      ]
    },
