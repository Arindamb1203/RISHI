      "question_text": "If x + y + z = 0, prove that x³ + y³ + z³ = 3xyz.",
      "correct_answer": "3xyz",
      "solution_steps": [
        {"step_number": 1, "instruction": "Use: x³+y³+z³−3xyz = (x+y+z)(x²+y²+z²−xy−yz−zx)", "working": "Since x+y+z = 0 (given), RHS = 0", "result": "x³+y³+z³−3xyz = 0", "voice_text": "The identity says x cubed plus y cubed plus z cubed minus 3xyz equals x plus y plus z times the rest. Since x plus y plus z is zero, the right side is zero."},
        {"step_number": 2, "instruction": "Rearrange", "working": "x³+y³+z³ = 3xyz", "result": "Proved ✓", "voice_text": "Therefore x cubed plus y cubed plus z cubed equals 3xyz."}
      ],
      "source": "NCT", "verified": true, "times_served": 0, "times_correct": 0, "times_wrong": 0
