      "question_text": "Is (x − 2) a factor of p(x) = x³ − 3x + 2? Yes or No.",
      "correct_answer": "yes",
      "solution_steps": [
        {"step_number": 1, "instruction": "By Factor Theorem: check p(2) = 0", "working": "p(2) = 8 − 6 + 2 = 4", "result": "p(2) = 4 ≠ 0", "voice_text": "Substitute x equals 2. 8 minus 6 plus 2 equals 4, not zero."},
        {"step_number": 2, "instruction": "Since p(2) ≠ 0", "working": "(x − 2) is NOT a factor", "result": "Answer: No", "voice_text": "Since the result is not zero, x minus 2 is not a factor."}
      ],
      "source": "EXM", "verified": true, "times_served": 0, "times_correct": 0, "times_wrong": 0
    },
    {
