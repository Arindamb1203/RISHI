      "question_text": "Using Factor Theorem, check if (x + 1) is a factor of x³ + x² + x + 1.",
      "correct_answer": "yes",
      "solution_steps": [
        {"step_number": 1, "instruction": "For (x+1): check p(−1) = 0", "working": "p(−1) = (−1)³ + (−1)² + (−1) + 1 = −1 + 1 − 1 + 1", "result": "= 0 ✓", "voice_text": "Substitute x equals negative 1. Negative 1 plus 1 minus 1 plus 1 equals zero."},
        {"step_number": 2, "instruction": "Since p(−1) = 0", "working": "Factor Theorem confirms", "result": "Yes, (x + 1) is a factor", "voice_text": "Since the result is zero, x plus 1 is a factor."}
      ],
      "source": "NCT", "verified": true, "times_served": 0, "times_correct": 0, "times_wrong": 0
