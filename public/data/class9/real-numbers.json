    {
      "id": "Q-C9-RNS-005",
      "chapter": "real-numbers",
      "topic": "decimal-expansions",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Without performing long division, state whether 64/455 has a terminating or non-terminating repeating decimal expansion.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "non-terminating repeating",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Factorise the denominator 455",
          "working": "455 = 5 × 91 = 5 × 7 × 13",
          "result": "Denominator has factors 7 and 13 (other than 2 and 5)",
          "voice_text": "Factorise 455. It equals 5 times 7 times 13."
        },
        {
          "step_number": 2,
          "instruction": "Apply the rule",
          "working": "Since denominator has prime factors other than 2 and 5 (has 7 and 13)",
          "result": "64/455 has non-terminating repeating decimal expansion",
          "voice_text": "Because the denominator has 7 and 13 as factors, the decimal will be non-terminating repeating."
        }
      ],
      "trick_id": null,
      "source": "EXM",
