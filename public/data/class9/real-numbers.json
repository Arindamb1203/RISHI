    {
      "id": "Q-C9-RNS-012",
      "chapter": "real-numbers",
      "topic": "laws-of-exponents",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 3,
      "question_text": "If a = 2 + √3, find the value of a − 1/a.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2√3",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find 1/a",
          "working": "1/a = 1/(2+√3). Rationalise: multiply by (2−√3)/(2−√3)",
          "result": "(2−√3)/(4−3) = 2−√3",
          "voice_text": "To find 1 over a, rationalise by multiplying by the conjugate 2 minus root 3."
        },
        {
          "step_number": 2,
          "instruction": "Find a − 1/a",
          "working": "(2+√3) − (2−√3) = 2+√3 − 2+√3",
          "result": "2√3",
          "voice_text": "Subtract. 2 minus 2 is 0. Root 3 plus root 3 is 2 root 3."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
