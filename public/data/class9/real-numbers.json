    {
      "id": "Q-C9-RNS-008",
      "chapter": "real-numbers",
      "topic": "operations-on-real-numbers",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Simplify: (√5 + √2)²",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "7 + 2√10",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply (a+b)² = a² + 2ab + b²",
          "working": "(√5)² + 2(√5)(√2) + (√2)²",
          "result": "5 + 2√10 + 2",
          "voice_text": "Use the identity: a plus b whole square equals a squared plus 2ab plus b squared."
        },
        {
          "step_number": 2,
          "instruction": "Simplify",
          "working": "5 + 2 + 2√10 = 7 + 2√10",
          "result": "7 + 2√10",
          "voice_text": "5 plus 2 is 7. The answer is 7 plus 2 root 10."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
