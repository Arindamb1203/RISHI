    {
      "id": "Q-C9-RNS-009",
      "chapter": "real-numbers",
      "topic": "operations-on-real-numbers",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Rationalise the denominator: 1/(√7 − √6)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "√7 + √6",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Multiply numerator and denominator by the conjugate",
          "working": "[1 × (√7 + √6)] / [(√7 − √6)(√7 + √6)]",
          "result": "(√7 + √6) / (7 − 6)",
          "voice_text": "Multiply top and bottom by root 7 plus root 6, which is the conjugate of the denominator."
        },
        {
          "step_number": 2,
          "instruction": "Simplify denominator using (a−b)(a+b) = a²−b²",
          "working": "(√7)² − (√6)² = 7 − 6 = 1",
          "result": "(√7 + √6) / 1 = √7 + √6",
          "voice_text": "The denominator becomes 7 minus 6 which is 1. So the answer is root 7 plus root 6."
        }
      ],
      "trick_id": null,
      "source": "RSA",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
