    {
      "id": "Q-C9-RNS-013",
      "chapter": "real-numbers",
      "topic": "decimal-expansions",
      "type": "SHORT",
      "difficulty": "hard",
      "marks": 3,
      "question_text": "Express 0.4̄7̄ (0.474747...) as a fraction in the form p/q.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "47/99",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Let x = 0.474747...",
          "working": "x = 0.474747...",
          "result": "Equation set",
          "voice_text": "Let x equal 0.474747 repeating."
        },
        {
          "step_number": 2,
          "instruction": "Since 2 digits repeat, multiply by 100",
          "working": "100x = 47.474747...",
          "result": "100x = 47.4747...",
          "voice_text": "Two digits repeat, so multiply by 100."
        },
        {
          "step_number": 3,
          "instruction": "Subtract original equation",
          "working": "100x − x = 47.4747... − 0.4747...",
          "result": "99x = 47",
          "voice_text": "Subtract. The repeating part cancels. 99x equals 47."
        },
        {
          "step_number": 4,
          "instruction": "Solve",
          "working": "x = 47/99",
          "result": "47/99",
          "voice_text": "x equals 47 over 99. Check that HCF of 47 and 99 is 1 — it is, so this is in lowest terms."
        }
      ],
      "trick_id": null,
      "source": "CBP",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
