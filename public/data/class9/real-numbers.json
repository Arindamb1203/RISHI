  "questions": [

    {
      "id": "Q-C9-RNS-001",
      "chapter": "real-numbers",
      "topic": "rational-irrational-classification",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "Which of the following is an irrational number?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: √9", "B: √12", "C: √25", "D: √49"],
      "correct_answer": "B",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Check each option",
          "working": "√9 = 3, √25 = 5, √49 = 7 — all perfect squares, hence rational",
          "result": "√12 = 2√3 — not a perfect square",
          "voice_text": "A number is irrational if it cannot be written as p divided by q. Check each square root."
        },
        {
          "step_number": 2,
          "instruction": "Confirm √12",
          "working": "√12 = √(4×3) = 2√3 ≈ 3.464...",
          "result": "Non-terminating, non-repeating → Irrational",
          "voice_text": "Root 12 equals 2 root 3, which is non-terminating and non-repeating. So it is irrational."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C9-RNS-002",
      "chapter": "real-numbers",
      "topic": "rational-irrational-classification",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "Is zero a rational number?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: No, zero has no form", "B: Yes, it can be written as 0/1", "C: Yes, but only as 0/0", "D: No, it is irrational"],
      "correct_answer": "B",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Recall the definition of rational number",
          "working": "A rational number is any number that can be written as p/q where p, q are integers and q ≠ 0",
          "result": "0 = 0/1 = 0/2 = 0/3 etc.",
          "voice_text": "Zero can be written as 0 over 1, 0 over 2, and so on. So zero is a rational number."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C9-RNS-003",
      "chapter": "real-numbers",
      "topic": "rational-irrational-classification",
      "type": "FILLIN",
      "difficulty": "easy",
      "marks": 1,
