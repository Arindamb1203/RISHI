    {
      "id": "Q-C9-RNS-004",
      "chapter": "real-numbers",
      "topic": "decimal-expansions",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "The decimal expansion of 7/8 is:",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 0.875 (terminating)", "B: 0.8̄7̄5̄ (non-terminating repeating)", "C: 0.8750000... (non-terminating non-repeating)", "D: Cannot be determined"],
      "correct_answer": "A",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Check denominator in lowest terms",
          "working": "8 = 2³. Denominator has only factor 2 → terminating decimal",
          "result": "7/8 will terminate",
          "voice_text": "If the denominator in lowest terms has only 2s and 5s as factors, the decimal terminates."
        },
        {
          "step_number": 2,
          "instruction": "Divide 7 by 8",
          "working": "7 ÷ 8 = 0.875",
          "result": "0.875 — terminates after 3 decimal places",
          "voice_text": "7 divided by 8 equals 0.875. It terminates."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
