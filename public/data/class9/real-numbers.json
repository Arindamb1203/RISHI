    {
      "id": "Q-C9-RNS-006",
      "chapter": "real-numbers",
      "topic": "irrational-numbers",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Prove that √2 is irrational.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Proof by contradiction",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Assume the opposite",
          "working": "Assume √2 is rational → √2 = p/q where p, q are integers, q ≠ 0, and HCF(p,q) = 1",
          "result": "Starting assumption set",
          "voice_text": "To prove by contradiction, we first assume that root 2 IS rational."
        },
        {
          "step_number": 2,
          "instruction": "Square both sides",
          "working": "2 = p²/q² → p² = 2q²",
          "result": "p² is even → p is even",
          "voice_text": "Squaring both sides gives p squared equals 2q squared. So p squared is even, which means p itself is even."
        },
        {
          "step_number": 3,
          "instruction": "Let p = 2m",
          "working": "(2m)² = 2q² → 4m² = 2q² → q² = 2m²",
          "result": "q² is even → q is even",
          "voice_text": "Since p is even, write p as 2m. Substituting gives q squared equals 2m squared. So q is also even."
        },
        {
          "step_number": 4,
          "instruction": "Reach contradiction",
          "working": "Both p and q are even → HCF(p,q) ≥ 2 → contradicts HCF(p,q) = 1",
          "result": "Contradiction! Our assumption was wrong.",
          "voice_text": "Both p and q are even, so they share factor 2. But we said HCF is 1. Contradiction! So root 2 is irrational."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C9-RNS-007",
      "chapter": "real-numbers",
      "topic": "irrational-numbers",
      "type": "MCQ",
      "difficulty": "medium",
      "marks": 1,
      "question_text": "Which of the following is rational?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: (3+√23) − √23", "B: 2√7/7√7", "C: Both A and B", "D: Neither A nor B"],
      "correct_answer": "C",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Simplify option A",
          "working": "(3+√23) − √23 = 3",
          "result": "3 is rational",
          "voice_text": "In option A, root 23 cancels out. We get 3, which is rational."
        },
        {
          "step_number": 2,
          "instruction": "Simplify option B",
          "working": "2√7 / 7√7 = 2/7",
          "result": "2/7 is rational",
          "voice_text": "In option B, root 7 cancels. We get 2 over 7, which is rational."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
