    {
      "id": "Q-C9-RNS-010",
      "chapter": "real-numbers",
      "topic": "laws-of-exponents",
      "type": "FILLIN",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "Simplify: 2^(2/3) × 2^(1/5) = 2^(____)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "13/15",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply law: aᵐ × aⁿ = aᵐ⁺ⁿ",
          "working": "2^(2/3) × 2^(1/5) = 2^(2/3 + 1/5)",
          "result": "Add the exponents",
          "voice_text": "When multiplying same bases, add the exponents."
        },
        {
          "step_number": 2,
          "instruction": "Add 2/3 + 1/5",
          "working": "LCM of 3 and 5 is 15. (2/3 + 1/5) = 10/15 + 3/15 = 13/15",
          "result": "2^(13/15)",
          "voice_text": "LCM of 3 and 5 is 15. 2 over 3 is 10 over 15. 1 over 5 is 3 over 15. Sum is 13 over 15."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
