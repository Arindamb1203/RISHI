    {
      "id": "Q-C9-RNS-015",
      "chapter": "real-numbers",
      "topic": "rational-irrational-classification",
      "type": "SHORT",
      "difficulty": "hard",
      "marks": 3,
      "question_text": "Find two irrational numbers between 2 and 3.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "√5 and √6 (or any valid irrational between 2 and 3)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Note that 2 = √4 and 3 = √9",
          "working": "Any √n where 4 < n < 9 and n is not a perfect square will be irrational and lie between 2 and 3",
          "result": "n can be 5, 6, 7, or 8",
          "voice_text": "Since 2 equals root 4 and 3 equals root 9, we need irrational square roots between root 4 and root 9."
        },
        {
          "step_number": 2,
          "instruction": "Choose two values",
          "working": "√5 ≈ 2.236 and √6 ≈ 2.449",
          "result": "√5 and √6 are irrational numbers between 2 and 3",
          "voice_text": "Root 5 is approximately 2.236 and root 6 is approximately 2.449. Both lie between 2 and 3 and are irrational."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
