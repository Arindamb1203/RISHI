    {
      "id": "Q-C9-RNS-014",
      "chapter": "real-numbers",
      "topic": "operations-on-real-numbers",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "If x = 3 − 2√2, find √x + 1/√x.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2√2",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Rewrite x as a perfect square",
          "working": "3 − 2√2 = 2 − 2√2 + 1 = (√2 − 1)²",
          "result": "x = (√2 − 1)²",
          "voice_text": "Notice that 3 minus 2 root 2 equals root 2 minus 1, all squared."
        },
        {
          "step_number": 2,
          "instruction": "Find √x",
          "working": "√x = √2 − 1",
          "result": "√x = √2 − 1",
          "voice_text": "So root x equals root 2 minus 1."
        },
        {
          "step_number": 3,
          "instruction": "Find 1/√x",
          "working": "1/(√2−1) × (√2+1)/(√2+1) = (√2+1)/(2−1) = √2+1",
          "result": "1/√x = √2 + 1",
          "voice_text": "Rationalise 1 over root x. Multiply by conjugate. Get root 2 plus 1."
        },
        {
          "step_number": 4,
          "instruction": "Add",
          "working": "(√2 − 1) + (√2 + 1) = 2√2",
          "result": "2√2",
          "voice_text": "Adding gives 2 root 2. The negative 1 and positive 1 cancel."
        }
      ],
      "trick_id": null,
      "source": "OLY",
      "cbse_pattern": false,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
