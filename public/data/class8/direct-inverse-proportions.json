    {
      "id": "Q-C8-DIP-003",
      "chapter": "direct-inverse-proportions",
      "topic": "inverse-proportion",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "If 8 workers can complete a task in 12 days, how many days will 16 workers take to complete the same task?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "6",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Identify type of proportion",
          "working": "More workers → fewer days. Inverse proportion.",
          "result": "Inverse proportion",
          "voice_text": "More workers means less time. This is inverse proportion."
        },
        {
          "step_number": 2,
          "instruction": "Apply inverse proportion: x₁y₁ = x₂y₂",
          "working": "8 × 12 = 16 × d → d = 96/16 = 6 days",
          "result": "6 days",
          "voice_text": "Product remains constant in inverse proportion. 8 times 12 equals 16 times d. d equals 6."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
