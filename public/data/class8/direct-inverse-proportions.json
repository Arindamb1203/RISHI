    {
      "id": "Q-C8-DIP-001",
      "chapter": "direct-inverse-proportions",
      "topic": "direct-proportion",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "If x and y are in direct proportion and x = 4 when y = 12, find y when x = 7.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 18", "B: 21", "C: 24", "D: 28"],
      "correct_answer": "B",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use direct proportion: x/y = constant",
          "working": "4/12 = 7/y → y = 7 × 12/4 = 21",
          "result": "y = 21",
          "voice_text": "In direct proportion, the ratio is constant. Cross multiply to find y."
        }
      ],
      "trick_id": null,
      "source": "NCT",
