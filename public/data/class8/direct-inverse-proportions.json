      "correct_answer": "405",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "More pens → more cost. Direct proportion.",
          "working": "225/15 = c/27 → c = 225 × 27/15 = 15 × 27 = 405",
          "result": "₹405",
          "voice_text": "Direct proportion. 225 divided by 15 is 15. 15 times 27 equals ₹405."
        }
      ],
      "trick_id": null,
