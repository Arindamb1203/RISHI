    {
      "id": "Q-C8-DIP-008",
      "chapter": "direct-inverse-proportions",
      "topic": "direct-proportion",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "A map is drawn to a scale of 1:50000. Find (i) the actual distance if the map distance is 4.5 cm, (ii) the map distance if the actual distance is 15 km.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2.25 km, 30 cm",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Understand scale 1:50000",
          "working": "1 cm on map = 50000 cm = 500 m = 0.5 km in reality",
          "result": "1 cm = 0.5 km",
          "voice_text": "Scale 1 to 50000 means 1 cm on map equals 50000 cm or 0.5 km in real life."
        },
        {
          "step_number": 2,
          "instruction": "Map 4.5 cm → actual distance",
          "working": "4.5 × 0.5 = 2.25 km",
          "result": "2.25 km",
          "voice_text": "4.5 cm on map equals 2.25 km in reality."
        },
        {
          "step_number": 3,
          "instruction": "Actual 15 km → map distance",
          "working": "15 km = 1500000 cm. Map = 1500000/50000 = 30 cm",
          "result": "30 cm",
          "voice_text": "Convert 15 km to cm first, then divide by the scale. Map distance is 30 cm."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-DIP-009",
      "chapter": "direct-inverse-proportions",
      "topic": "inverse-proportion",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A cistern can be filled by pipe A in 6 hours and by pipe B in 8 hours. If both pipes are opened together, in how many hours will the cistern be filled?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "24/7",
      "answer_tolerance": 0.1,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find work done per hour by each pipe",
          "working": "Pipe A: 1/6 per hour | Pipe B: 1/8 per hour",
          "result": "Rates identified",
          "voice_text": "Pipe A fills 1 by 6 of the cistern per hour. Pipe B fills 1 by 8 per hour."
        },
        {
          "step_number": 2,
          "instruction": "Combined rate",
          "working": "1/6 + 1/8 = 4/24 + 3/24 = 7/24 per hour",
          "result": "7/24 per hour",
          "voice_text": "Together they fill 7 by 24 of the cistern every hour."
        },
        {
          "step_number": 3,
          "instruction": "Total time",
          "working": "Time = 1 ÷ (7/24) = 24/7 hours ≈ 3 hours 26 minutes",
          "result": "24/7 hours",
          "voice_text": "Total time equals 1 divided by the combined rate. 24 by 7 hours."
        }
      ],
      "trick_id": null,
      "source": "OLY",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-DIP-010",
      "chapter": "direct-inverse-proportions",
      "topic": "direct-proportion",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A photograph of a bacterium was enlarged 50000 times and the enlarged length was 5 cm. What was the actual length of the bacterium? Express in standard form.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1 × 10⁻⁴ cm",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Set up direct proportion",
          "working": "Enlarged: Actual = 50000:1. Enlarged length = 5 cm.",
          "result": "Actual = 5/50000",
          "voice_text": "The actual size is the enlarged size divided by the magnification factor."
        },
        {
          "step_number": 2,
          "instruction": "Calculate actual length",
          "working": "Actual = 5/50000 = 1/10000 = 0.0001 cm",
          "result": "0.0001 cm",
          "voice_text": "5 divided by 50000 equals 0.0001 cm."
        },
        {
          "step_number": 3,
          "instruction": "Express in standard form",
          "working": "0.0001 = 1 × 10⁻⁴ cm",
          "result": "1 × 10⁻⁴ cm",
          "voice_text": "In standard form, 0.0001 is 1 times 10 to the power negative 4."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
