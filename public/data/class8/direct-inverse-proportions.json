    {
      "id": "Q-C8-DIP-002",
      "chapter": "direct-inverse-proportions",
      "topic": "direct-proportion",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "A car travels 240 km in 4 hours. How far will it travel in 7 hours at the same speed?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "420",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Identify type of proportion",
          "working": "More hours → more distance. Direct proportion.",
          "result": "Direct proportion",
          "voice_text": "As hours increase, distance increases. This is direct proportion."
        },
        {
          "step_number": 2,
          "instruction": "Apply direct proportion",
          "working": "240/4 = d/7 → d = 240 × 7/4 = 420 km",
          "result": "420 km",
          "voice_text": "Cross multiply. 240 times 7 divided by 4 equals 420 km."
        }
      ],
      "trick_id": null,
      "source": "NCT",
