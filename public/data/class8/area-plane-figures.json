    {
      "id": "Q-C8-APF-012",
      "chapter": "area-plane-figures",
      "topic": "composite-figures",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A floor is in the shape of a trapezium with parallel sides 20 m and 14 m, and height 8 m. It needs to be tiled using tiles of size 50 cm × 40 cm. Find the number of tiles required.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "680",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find floor area",
          "working": "Area = ½ × (20+14) × 8 = ½ × 34 × 8 = 136 m²",
          "result": "136 m²",
          "voice_text": "Area of trapezium floor is 136 square metres."
        },
        {
          "step_number": 2,
          "instruction": "Convert to cm²",
          "working": "136 m² = 136 × 10000 = 1360000 cm²",
          "result": "1360000 cm²",
          "voice_text": "Convert to square centimetres. 1 square metre equals 10000 square centimetres."
        },
        {
          "step_number": 3,
          "instruction": "Find area of one tile",
          "working": "50 × 40 = 2000 cm² per tile",
          "result": "2000 cm²",
          "voice_text": "Each tile is 50 cm times 40 cm = 2000 square centimetres."
        },
        {
          "step_number": 4,
          "instruction": "Number of tiles",
          "working": "1360000 ÷ 2000 = 680 tiles",
          "result": "680 tiles",
          "voice_text": "Divide total area by tile area. 680 tiles needed."
        }
      ],
      "trick_id": null,
      "source": "CBP",
      "cbse_pattern": true,
