    {
      "id": "Q-C8-APF-003",
      "chapter": "area-plane-figures",
      "topic": "general-quadrilateral",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Find the area of a general quadrilateral ABCD where diagonal AC = 10 cm and perpendiculars from B and D to AC are 4 cm and 5 cm respectively.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "45",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply quadrilateral area formula",
          "working": "Area = ½ × d × (h₁ + h₂) where d = diagonal, h₁ and h₂ = perpendicular heights",
          "result": "= ½ × 10 × (4 + 5)",
          "voice_text": "Area of a quadrilateral equals half the diagonal times the sum of the two heights from opposite vertices."
        },
        {
          "step_number": 2,
          "instruction": "Calculate",
          "working": "= ½ × 10 × 9 = 45 cm²",
          "result": "45 cm²",
          "voice_text": "Half of 10 times 9 equals 45 square centimetres."
        }
      ],
      "trick_id": null,
