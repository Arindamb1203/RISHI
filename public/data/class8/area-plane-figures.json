      "options": null,
      "correct_answer": "2520",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Area of square",
          "working": "56 × 56 = 3136 m²",
          "result": "3136 m²",
          "voice_text": "Area of the square park is 56 squared = 3136 square metres."
        },
        {
          "step_number": 2,
          "instruction": "Area of one circular pond",
          "working": "π × 7² = (22/7) × 49 = 154 m²",
          "result": "154 m²",
          "voice_text": "One circular pond has area 154 square metres."
        },
        {
          "step_number": 3,
          "instruction": "Total area of 4 ponds",
          "working": "4 × 154 = 616 m²",
          "result": "616 m²",
          "voice_text": "Four ponds together take up 616 square metres."
        },
        {
          "step_number": 4,
          "instruction": "Remaining walking area",
          "working": "3136 − 616 = 2520 m²",
          "result": "2520 m²",
          "voice_text": "Subtract pond area from total. Walking area is 2520 square metres."
        }
      ],
      "trick_id": null,
