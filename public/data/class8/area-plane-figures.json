    {
      "id": "Q-C8-APF-005",
      "chapter": "area-plane-figures",
      "topic": "circle",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Find the area and circumference of a circle with radius 7 cm. (Use π = 22/7)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Area=154 cm², Circumference=44 cm",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Calculate area",
          "working": "Area = πr² = (22/7) × 7 × 7 = 22 × 7 = 154 cm²",
          "result": "154 cm²",
          "voice_text": "Area equals pi r squared. 22 by 7 times 7 times 7 equals 154."
        },
        {
          "step_number": 2,
          "instruction": "Calculate circumference",
          "working": "C = 2πr = 2 × (22/7) × 7 = 2 × 22 = 44 cm",
          "result": "44 cm",
          "voice_text": "Circumference equals 2 pi r. 2 times 22 by 7 times 7 equals 44."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-APF-006",
      "chapter": "area-plane-figures",
      "topic": "circle",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The circumference of a circle is 88 cm. Find its radius and area. (Use π = 22/7)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Radius=14 cm, Area=616 cm²",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find radius from circumference",
          "working": "2πr = 88 → r = 88 × 7 / (2 × 22) = 616/44 = 14 cm",
          "result": "r = 14 cm",
          "voice_text": "Circumference equals 2 pi r. Solving for r gives 14 cm."
        },
        {
          "step_number": 2,
          "instruction": "Find area",
          "working": "Area = πr² = (22/7) × 14 × 14 = 22 × 2 × 14 = 616 cm²",
          "result": "616 cm²",
          "voice_text": "Area equals pi r squared. 22 by 7 times 14 squared equals 616."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
