    {
      "id": "Q-C8-APF-007",
      "chapter": "area-plane-figures",
      "topic": "trapezium",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The area of a trapezium is 168 cm². Its parallel sides are 10 cm and 18 cm. Find its height.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "12",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply formula and solve for h",
          "working": "168 = ½ × (10 + 18) × h = ½ × 28 × h = 14h",
          "result": "14h = 168",
          "voice_text": "Substitute the known values. 168 equals 14 times h."
        },
        {
          "step_number": 2,
          "instruction": "Solve",
          "working": "h = 168 ÷ 14 = 12 cm",
          "result": "12 cm",
          "voice_text": "Divide 168 by 14. Height equals 12 cm."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-APF-008",
      "chapter": "area-plane-figures",
      "topic": "composite-figures",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "A park is in the shape of a rectangle 60 m × 40 m. A circular pond of radius 7 m is dug inside. Find the area of the remaining land. (π = 22/7)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2246",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find rectangle area",
          "working": "60 × 40 = 2400 m²",
          "result": "2400 m²",
          "voice_text": "Area of rectangle equals length times width. 60 times 40 is 2400."
        },
        {
          "step_number": 2,
          "instruction": "Find circle area",
          "working": "π × 7² = (22/7) × 49 = 154 m²",
          "result": "154 m²",
          "voice_text": "Area of the pond is pi r squared. 22 by 7 times 49 equals 154."
        },
        {
          "step_number": 3,
          "instruction": "Subtract",
          "working": "2400 − 154 = 2246 m²",
          "result": "2246 m²",
          "voice_text": "Remaining land equals 2400 minus 154 which is 2246 square metres."
        }
      ],
      "trick_id": null,
      "source": "RSA",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
