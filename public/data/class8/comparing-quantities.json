    {
      "id": "Q-C8-CMP-003",
      "chapter": "comparing-quantities",
      "topic": "profit-loss",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "A cycle is bought for ₹1200 and sold at a loss of 15%. Find the selling price.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1020",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find loss amount",
          "working": "Loss = 15% of 1200 = (15/100) × 1200 = ₹180",
          "result": "Loss = ₹180",
          "voice_text": "15 percent of 1200 is 180."
        },
        {
          "step_number": 2,
          "instruction": "Find SP",
          "working": "SP = CP − Loss = 1200 − 180 = ₹1020",
          "result": "₹1020",
          "voice_text": "Selling price equals cost price minus loss. 1200 minus 180 equals 1020."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
