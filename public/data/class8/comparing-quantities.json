    {
      "id": "Q-C8-CMP-009",
      "chapter": "comparing-quantities",
      "topic": "compound-interest",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Ramesh borrowed ₹25000 from a bank at 12% p.a. compound interest. What amount will he repay after 2 years? Also find the CI.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Amount=₹31360, CI=₹6360",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply compound interest formula",
          "working": "A = P(1 + R/100)ⁿ = 25000 × (1 + 12/100)²",
          "result": "= 25000 × (1.12)²",
          "voice_text": "Amount equals P times 1 plus R by 100 raised to n."
        },
        {
          "step_number": 2,
          "instruction": "Calculate (1.12)²",
          "working": "1.12 × 1.12 = 1.2544",
          "result": "1.2544",
          "voice_text": "1.12 squared equals 1.2544."
        },
        {
          "step_number": 3,
          "instruction": "Find amount",
          "working": "A = 25000 × 1.2544 = ₹31360",
          "result": "₹31360",
          "voice_text": "25000 times 1.2544 equals ₹31360."
        },
        {
          "step_number": 4,
          "instruction": "Find CI",
          "working": "CI = 31360 − 25000 = ₹6360",
          "result": "₹6360",
          "voice_text": "Compound interest is ₹6360."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
