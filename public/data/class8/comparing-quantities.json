    {
      "id": "Q-C8-CMP-012",
      "chapter": "comparing-quantities",
      "topic": "percentage",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "In an election, candidate A got 55% of the total votes. If candidate B got 18000 votes, find the total votes cast.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "40000",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find B's percentage",
          "working": "A got 55%, so B got 45% of total votes.",
          "result": "B = 45%",
          "voice_text": "If A got 55 percent, B got the remaining 45 percent."
        },
        {
          "step_number": 2,
          "instruction": "Find total votes",
          "working": "45% of total = 18000 → total = 18000 × 100/45 = 40000",
          "result": "40000 votes",
          "voice_text": "45 percent equals 18000. Total votes equals 18000 times 100 divided by 45 = 40000."
        }
      ],
      "trick_id": null,
