    {
      "id": "Q-C8-CMP-005",
      "chapter": "comparing-quantities",
      "topic": "compound-interest",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Find the compound interest on ₹10000 at 10% per annum for 2 years.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2100",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply CI formula",
          "working": "A = P(1 + R/100)ⁿ = 10000 × (1.1)² = 10000 × 1.21 = ₹12100",
          "result": "A = ₹12100",
          "voice_text": "Amount equals P times 1 plus r by 100 to the power n. 10000 times 1.21 equals 12100."
        },
        {
          "step_number": 2,
          "instruction": "Find CI",
          "working": "CI = A − P = 12100 − 10000 = ₹2100",
          "result": "₹2100",
          "voice_text": "Compound interest equals amount minus principal. 2100 rupees."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
