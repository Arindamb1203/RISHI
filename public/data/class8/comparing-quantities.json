      "times_wrong": 0
    },

    {
      "id": "Q-C8-CMP-006",
      "chapter": "comparing-quantities",
      "topic": "compound-interest",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Find the difference between CI and SI on ₹8000 at 5% per annum for 2 years.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "20",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Calculate SI",
          "working": "SI = (8000 × 5 × 2)/100 = ₹800",
          "result": "SI = ₹800",
          "voice_text": "Simple interest for 2 years is ₹800."
        },
        {
          "step_number": 2,
          "instruction": "Calculate CI",
          "working": "A = 8000 × (1.05)² = 8000 × 1.1025 = ₹8820. CI = 820.",
          "result": "CI = ₹820",
          "voice_text": "Compound interest is ₹820."
        },
        {
          "step_number": 3,
          "instruction": "Find difference",
          "working": "CI − SI = 820 − 800 = ₹20",
          "result": "₹20",
          "voice_text": "The difference is ₹20. CI is always greater than SI for the same period and rate."
        }
      ],
      "trick_id": "T-CMP-001",
      "source": "CBP",
      "cbse_pattern": true,
