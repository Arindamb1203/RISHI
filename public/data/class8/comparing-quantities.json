    {
      "id": "Q-C8-CMP-002",
      "chapter": "comparing-quantities",
      "topic": "profit-loss",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "A shopkeeper bought an article for ₹400 and sold it for ₹500. Find the profit percentage.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "25",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find profit",
          "working": "Profit = SP − CP = 500 − 400 = ₹100",
          "result": "Profit = ₹100",
          "voice_text": "Profit equals selling price minus cost price."
        },
        {
          "step_number": 2,
          "instruction": "Calculate profit %",
          "working": "Profit% = (Profit/CP) × 100 = (100/400) × 100 = 25%",
          "result": "25%",
          "voice_text": "Profit percent equals profit divided by cost price times 100. That gives 25 percent."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
