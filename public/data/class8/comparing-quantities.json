    {
      "id": "Q-C8-CMP-004",
      "chapter": "comparing-quantities",
      "topic": "simple-interest",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Find the simple interest on ₹5000 at 8% per annum for 3 years.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1200",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply SI formula",
          "working": "SI = (P × R × T) / 100 = (5000 × 8 × 3) / 100",
          "result": "= 120000/100 = ₹1200",
          "voice_text": "Simple interest equals P times R times T divided by 100. 5000 times 8 times 3 divided by 100 equals 1200."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
