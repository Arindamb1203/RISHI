    {
      "id": "Q-C8-CMP-007",
      "chapter": "comparing-quantities",
      "topic": "discount",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "A TV with marked price ₹15000 is sold at a discount of 12%. Find the discount and selling price.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Discount=₹1800, SP=₹13200",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find discount",
          "working": "Discount = 12% of 15000 = (12/100) × 15000 = ₹1800",
          "result": "₹1800",
          "voice_text": "Discount is 12 percent of the marked price."
        },
        {
          "step_number": 2,
          "instruction": "Find SP",
          "working": "SP = Marked Price − Discount = 15000 − 1800 = ₹13200",
          "result": "₹13200",
          "voice_text": "Selling price is marked price minus discount. ₹13200."
        }
      ],
      "trick_id": null,
      "source": "NCT",
