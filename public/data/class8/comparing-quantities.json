    {
      "id": "Q-C8-CMP-010",
      "chapter": "comparing-quantities",
      "topic": "profit-loss",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A trader sells two articles for ₹3000 each. On one he makes a profit of 20% and on the other a loss of 20%. Find the overall profit or loss percentage.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Loss of 4%",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find CP of item sold at 20% profit",
          "working": "SP = 3000 = CP × 1.2 → CP₁ = 3000/1.2 = ₹2500",
          "result": "CP₁ = ₹2500",
          "voice_text": "If selling price is 3000 with 20 percent profit, cost price is 2500."
        },
        {
          "step_number": 2,
          "instruction": "Find CP of item sold at 20% loss",
          "working": "SP = 3000 = CP × 0.8 → CP₂ = 3000/0.8 = ₹3750",
          "result": "CP₂ = ₹3750",
          "voice_text": "If selling price is 3000 with 20 percent loss, cost price is 3750."
        },
        {
          "step_number": 3,
          "instruction": "Calculate overall",
          "working": "Total CP = 2500+3750=6250 | Total SP = 6000 | Loss = 250",
          "result": "Loss = ₹250",
          "voice_text": "Total cost is 6250. Total selling price is 6000. There is an overall loss of 250."
        },
        {
          "step_number": 4,
          "instruction": "Loss percentage",
          "working": "Loss% = (250/6250) × 100 = 4%",
          "result": "Loss of 4%",
          "voice_text": "Overall loss is 4 percent. Note: same % profit and loss always results in loss!"
        }
      ],
      "trick_id": "T-CMP-002",
      "source": "OLY",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-CMP-011",
      "chapter": "comparing-quantities",
      "topic": "compound-interest",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "At what rate percent per annum will ₹6000 amount to ₹6615 in 2 years with compound interest?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "5",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use CI formula",
          "working": "6615 = 6000 × (1 + R/100)²",
          "result": "(1 + R/100)² = 6615/6000 = 1.1025",
          "voice_text": "Set up the compound interest equation."
        },
        {
          "step_number": 2,
          "instruction": "Find square root",
          "working": "1 + R/100 = √1.1025 = 1.05",
          "result": "R/100 = 0.05",
          "voice_text": "Take the square root of both sides. 1.1025 square root is 1.05."
        },
        {
          "step_number": 3,
          "instruction": "Solve for R",
          "working": "R = 5%",
          "result": "5% per annum",
          "voice_text": "R equals 5 percent per annum."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
