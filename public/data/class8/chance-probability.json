    {
      "id": "Q-C8-PRB-005",
      "chapter": "chance-probability",
      "topic": "die",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "A die is rolled once. Find the probability of getting (i) an even number, (ii) a multiple of 3.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1/2, 1/3",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Total outcomes",
          "working": "{1,2,3,4,5,6} → 6",
          "result": "Total = 6",
          "voice_text": "Die has 6 outcomes."
        },
        {
          "step_number": 2,
          "instruction": "P(even number)",
          "working": "Even: {2,4,6} → 3 outcomes → P = 3/6 = 1/2",
          "result": "1/2",
          "voice_text": "Even numbers on a die are 2, 4, and 6. Probability is 3 by 6 = 1 by 2."
        },
        {
          "step_number": 3,
          "instruction": "P(multiple of 3)",
          "working": "Multiples of 3: {3,6} → 2 outcomes → P = 2/6 = 1/3",
          "result": "1/3",
          "voice_text": "Multiples of 3 on a die are 3 and 6. Probability is 2 by 6 = 1 by 3."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
