    {
      "id": "Q-C8-PRB-003",
      "chapter": "chance-probability",
      "topic": "coin",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "A coin is tossed once. What is the probability of getting a tail?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 0", "B: 1/4", "C: 1/2", "D: 1"],
      "correct_answer": "C",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "List all outcomes",
          "working": "{Head, Tail} → Total = 2",
          "result": "Total outcomes = 2",
          "voice_text": "When a coin is tossed, there are only two possible outcomes — Head or Tail."
        },
        {
          "step_number": 2,
          "instruction": "Count favourable outcomes",
          "working": "Tail = 1 outcome",
          "result": "Favourable = 1",
          "voice_text": "We want a Tail. There is only one Tail."
        },
        {
          "step_number": 3,
          "instruction": "Apply formula",
          "working": "P(Tail) = 1/2",
          "result": "1/2",
          "voice_text": "Probability equals favourable divided by total. 1 by 2."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
