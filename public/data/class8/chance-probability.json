    {
      "id": "Q-C8-PRB-006",
      "chapter": "chance-probability",
      "topic": "cards",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "A card is drawn at random from a well-shuffled deck of 52 cards. Find the probability that the card is: (i) a king, (ii) a red card, (iii) a face card.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1/13, 1/2, 3/13",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Total outcomes",
          "working": "52 cards in a standard deck",
          "result": "Total = 52",
          "voice_text": "A standard deck has 52 cards — 4 suits of 13 cards each."
        },
        {
          "step_number": 2,
          "instruction": "P(King)",
          "working": "4 kings in deck → P = 4/52 = 1/13",
          "result": "1/13",
          "voice_text": "There are 4 kings — one in each suit. Probability is 1 by 13."
        },
        {
          "step_number": 3,
          "instruction": "P(Red card)",
          "working": "Hearts + Diamonds = 26 red cards → P = 26/52 = 1/2",
          "result": "1/2",
          "voice_text": "Half the deck is red — 13 hearts and 13 diamonds. Probability is 1 by 2."
        },
        {
          "step_number": 4,
          "instruction": "P(Face card)",
          "working": "Jack, Queen, King × 4 suits = 12 face cards → P = 12/52 = 3/13",
          "result": "3/13",
          "voice_text": "Face cards are Jack, Queen, King — 3 per suit, 4 suits = 12 total. Probability is 3 by 13."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
