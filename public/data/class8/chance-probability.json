    {
      "id": "Q-C8-PRB-009",
      "chapter": "chance-probability",
      "topic": "complementary-events",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The probability that it will rain tomorrow is 0.35. What is the probability that it will NOT rain tomorrow?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "0.65",
      "answer_tolerance": 0.01,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use complementary event rule",
          "working": "P(not rain) = 1 − P(rain) = 1 − 0.35",
          "result": "0.65",
          "voice_text": "The probability of an event and its complement always add up to 1. So subtract from 1."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-PRB-010",
      "chapter": "chance-probability",
      "topic": "bag-balls",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A box contains 5 orange, 4 white and 3 blue marbles. If one marble is drawn at random, find the probability that it is (i) orange, (ii) not white, (iii) blue or white.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "5/12, 2/3, 7/12",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Total marbles",
          "working": "5 + 4 + 3 = 12",
          "result": "Total = 12",
          "voice_text": "Total marbles = 12."
        },
        {
          "step_number": 2,
          "instruction": "P(orange)",
          "working": "P = 5/12",
          "result": "5/12",
          "voice_text": "5 orange out of 12. Probability is 5 by 12."
        },
        {
          "step_number": 3,
          "instruction": "P(not white)",
          "working": "Not white = orange + blue = 5 + 3 = 8. P = 8/12 = 2/3",
          "result": "2/3",
          "voice_text": "Not white means orange or blue. That is 8 marbles. Probability is 2 by 3."
        },
        {
          "step_number": 4,
          "instruction": "P(blue or white)",
          "working": "Blue + white = 3 + 4 = 7. P = 7/12",
          "result": "7/12",
          "voice_text": "Blue or white means 7 marbles. Probability is 7 by 12."
        }
      ],
      "trick_id": null,
      "source": "CBP",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
