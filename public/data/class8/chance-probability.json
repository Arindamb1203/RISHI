    {
      "id": "Q-C8-PRB-004",
      "chapter": "chance-probability",
      "topic": "die",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "A die is thrown once. Find the probability of getting a number greater than 4.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1/3",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "List all outcomes",
          "working": "{1, 2, 3, 4, 5, 6} → Total = 6",
          "result": "Total = 6",
          "voice_text": "A standard die has 6 faces numbered 1 to 6."
        },
        {
          "step_number": 2,
          "instruction": "Identify favourable outcomes",
          "working": "Numbers greater than 4: {5, 6} → 2 outcomes",
          "result": "Favourable = 2",
          "voice_text": "Numbers greater than 4 are 5 and 6. Two favourable outcomes."
        },
        {
          "step_number": 3,
          "instruction": "Calculate",
          "working": "P = 2/6 = 1/3",
          "result": "1/3",
          "voice_text": "2 divided by 6, simplified to 1 by 3."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
