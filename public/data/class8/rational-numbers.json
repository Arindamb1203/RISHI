    {
      "id": "Q-C8-RAT-006",
      "chapter": "rational-numbers",
      "topic": "number-line",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Find 3 rational numbers between 1/4 and 1/2.",
