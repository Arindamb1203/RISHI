    {
      "id": "Q-C8-RAT-001",
      "chapter": "rational-numbers",
      "topic": "basic-definition",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "Which of the following is NOT a rational number?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 3/4", "B: −5/7", "C: √3", "D: 0"],
      "correct_answer": "C",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Recall definition",
          "working": "Rational number = p/q where p, q are integers and q ≠ 0. √3 cannot be expressed as p/q. It is irrational.",
          "result": "√3",
          "voice_text": "A rational number can be written as a fraction p by q. The square root of 3 cannot be written this way — it is irrational."
        }
      ],
      "trick_id": null,
      "source": "NCT",
