    {
      "id": "Q-C8-RAT-008",
      "chapter": "rational-numbers",
      "topic": "operations",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "Simplify: (3/4 + 1/6) ÷ (5/8 − 1/4).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "22/9",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Solve the numerator bracket",
          "working": "3/4 + 1/6 = 9/12 + 2/12 = 11/12",
          "result": "11/12",
          "voice_text": "First solve the bracket in the dividend. LCM of 4 and 6 is 12."
        },
        {
          "step_number": 2,
          "instruction": "Solve the denominator bracket",
          "working": "5/8 − 1/4 = 5/8 − 2/8 = 3/8",
          "result": "3/8",
          "voice_text": "Now solve the divisor bracket. LCM of 8 and 4 is 8."
        },
        {
          "step_number": 3,
          "instruction": "Divide",
          "working": "11/12 ÷ 3/8 = 11/12 × 8/3 = 88/36 = 22/9",
          "result": "22/9",
          "voice_text": "To divide fractions, multiply by the reciprocal. 11 by 12 times 8 by 3 simplifies to 22 by 9."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-RAT-009",
      "chapter": "rational-numbers",
      "topic": "properties",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Verify: (2/3 + 1/4) + 1/5 = 2/3 + (1/4 + 1/5) and name the property.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Both = 61/60, Associativity of addition",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Calculate LHS",
          "working": "(2/3 + 1/4) + 1/5 = (8/12 + 3/12) + 1/5 = 11/12 + 1/5 = 55/60 + 12/60 = 67/60",
          "result": "67/60... let me recalculate: 2/3=40/60, 1/4=15/60, 1/5=12/60. LHS=(40+15)/60+12/60=67/60",
          "voice_text": "Calculate the left side step by step using LCM."
        },
        {
          "step_number": 2,
          "instruction": "Calculate RHS",
          "working": "2/3 + (1/4 + 1/5) = 40/60 + (15+12)/60 = 40/60 + 27/60 = 67/60",
          "result": "67/60",
          "voice_text": "Both sides equal 67 by 60. This demonstrates the associative property of addition."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-RAT-010",
      "chapter": "rational-numbers",
      "topic": "operations",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Arrange in ascending order: −3/4, 5/−6, −7/8, 2/−3.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "−7/8, −5/6, −3/4, −2/3",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Make all negatives consistent",
          "working": "5/−6 = −5/6 | 2/−3 = −2/3",
          "result": "Numbers: −3/4, −5/6, −7/8, −2/3",
          "voice_text": "Move the negative sign to the numerator for clarity."
        },
        {
          "step_number": 2,
          "instruction": "Find common denominator",
          "working": "LCM of 4, 6, 8, 3 = 24. Convert: −18/24, −20/24, −21/24, −16/24",
          "result": "All in 24ths",
          "voice_text": "Convert all fractions to the same denominator of 24."
        },
        {
          "step_number": 3,
          "instruction": "Arrange ascending (most negative first)",
          "working": "−21/24 < −20/24 < −18/24 < −16/24",
          "result": "−7/8, −5/6, −3/4, −2/3",
          "voice_text": "For negative numbers, the one with largest absolute value is the smallest. Ascending order is −7/8, −5/6, −3/4, −2/3."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-RAT-011",
      "chapter": "rational-numbers",
      "topic": "properties",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Using distributive property, evaluate: (3/7 × −4/5) + (3/7 × −3/5).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "-3/7",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply distributive property a(b+c) = ab + ac",
          "working": "3/7 × (−4/5 + (−3/5))",
          "result": "3/7 × (−7/5)",
          "voice_text": "Take out 3 by 7 as common factor. The bracket becomes negative 4 by 5 plus negative 3 by 5."
        },
        {
          "step_number": 2,
          "instruction": "Solve the bracket",
          "working": "−4/5 + (−3/5) = −7/5",
          "result": "−7/5",
          "voice_text": "Add the fractions inside the bracket. Negative 4 plus negative 3 equals negative 7."
        },
        {
          "step_number": 3,
          "instruction": "Multiply",
          "working": "3/7 × (−7/5) = −21/35 = −3/5",
          "result": "−3/5",
          "voice_text": "Multiply. 3 times 7 in numerator gives 21. Simplify to −3/5."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
