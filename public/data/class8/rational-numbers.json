      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Recall multiplicative inverse",
          "working": "Multiplicative inverse of p/q is q/p. Inverse of −7/9 is −9/7.",
          "result": "−9/7",
          "voice_text": "The multiplicative inverse is the reciprocal — flip the fraction. The sign stays the same."
        }
      ],
