    {
      "id": "Q-C8-RAT-003",
      "chapter": "rational-numbers",
      "topic": "operations",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Add: 3/7 + (−5/7).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "-2/7",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Same denominator — add numerators",
          "working": "3/7 + (−5/7) = (3 − 5)/7 = −2/7",
          "result": "−2/7",
          "voice_text": "Since the denominators are the same, just add the numerators. 3 minus 5 equals negative 2."
        }
      ],
      "trick_id": null,
