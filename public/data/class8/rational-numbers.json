      "diagram_description": null,
      "options": null,
      "correct_answer": "Any three of: 3/8, 5/16, 7/16, 2/5, 3/10 etc.",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Make denominators same",
          "working": "1/4 = 4/16 and 1/2 = 8/16",
          "result": "Range: 4/16 to 8/16",
          "voice_text": "Convert to a common denominator. 1 by 4 equals 4 by 16 and 1 by 2 equals 8 by 16."
        },
        {
          "step_number": 2,
          "instruction": "List rational numbers in between",
          "working": "5/16, 6/16, 7/16 are between 4/16 and 8/16",
          "result": "5/16, 6/16, 7/16",
          "voice_text": "Three rational numbers between them are 5 by 16, 6 by 16, and 7 by 16."
        }
      ],
