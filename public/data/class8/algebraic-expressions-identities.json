    {
      "id": "Q-C8-ALG-006",
      "chapter": "algebraic-expressions-identities",
      "topic": "identity-2",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Using identity (a − b)² = a² − 2ab + b², expand (4x − 7)².",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "16x² − 56x + 49",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Identify a and b",
          "working": "a = 4x, b = 7",
          "result": "a and b identified",
          "voice_text": "Here a equals 4x and b equals 7."
        },
        {
          "step_number": 2,
          "instruction": "Apply identity",
          "working": "a² = 16x² | 2ab = 2×4x×7 = 56x | b² = 49",
          "result": "16x² − 56x + 49",
          "voice_text": "Square a, subtract double the product, then add square of b."
        }
      ],
      "trick_id": "T-ALG-001",
