    {
      "id": "Q-C8-ALG-003",
      "chapter": "algebraic-expressions-identities",
      "topic": "multiplication",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Multiply: 3x(2x² − 5x + 4).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "6x³ − 15x² + 12x",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Distribute 3x to each term",
          "working": "3x × 2x² = 6x³ | 3x × (−5x) = −15x² | 3x × 4 = 12x",
          "result": "Each term multiplied",
          "voice_text": "Multiply 3x by each term inside the bracket one by one."
        },
        {
          "step_number": 2,
          "instruction": "Write the final answer",
          "working": "6x³ − 15x² + 12x",
          "result": "6x³ − 15x² + 12x",
          "voice_text": "The final answer is 6x cubed minus 15x squared plus 12x."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
