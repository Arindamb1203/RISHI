    {
      "id": "Q-C8-ALG-007",
      "chapter": "algebraic-expressions-identities",
      "topic": "identity-3",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Evaluate 98 × 102 using a suitable identity.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "9996",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Rewrite using identity (a+b)(a−b)",
          "working": "98 × 102 = (100 − 2)(100 + 2)",
          "result": "a = 100, b = 2",
          "voice_text": "Notice that 98 is 100 minus 2, and 102 is 100 plus 2. This matches the identity a minus b times a plus b."
        },
        {
          "step_number": 2,
          "instruction": "Apply (a+b)(a−b) = a² − b²",
          "working": "100² − 2² = 10000 − 4",
          "result": "9996",
          "voice_text": "Square 100 to get 10000, subtract square of 2 which is 4. Answer is 9996."
        }
      ],
      "trick_id": "T-ALG-002",
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
