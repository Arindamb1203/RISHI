    {
      "id": "Q-C8-ALG-010",
      "chapter": "algebraic-expressions-identities",
      "topic": "subtraction",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Subtract (3a² − 5b + 2) from (7a² + 3b − 6).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "4a² + 8b − 8",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Set up subtraction",
          "working": "(7a² + 3b − 6) − (3a² − 5b + 2)",
          "result": "Change signs of second expression",
          "voice_text": "When subtracting, change the sign of every term in the expression being subtracted."
        },
        {
          "step_number": 2,
          "instruction": "Apply sign change and collect like terms",
          "working": "7a² − 3a² = 4a² | 3b + 5b = 8b | −6 − 2 = −8",
          "result": "4a² + 8b − 8",
          "voice_text": "Collect like terms after changing signs. Answer is 4a squared plus 8b minus 8."
        }
      ],
      "trick_id": null,
      "source": "RSA",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
