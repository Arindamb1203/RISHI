    {
      "id": "Q-C8-ALG-005",
      "chapter": "algebraic-expressions-identities",
      "topic": "identity-1",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Using identity (a + b)² = a² + 2ab + b², expand (3x + 5)².",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "9x² + 30x + 25",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Identify a and b",
          "working": "a = 3x, b = 5",
          "result": "a and b identified",
          "voice_text": "Here a equals 3x and b equals 5."
        },
        {
          "step_number": 2,
          "instruction": "Apply the identity",
          "working": "a² = (3x)² = 9x² | 2ab = 2×3x×5 = 30x | b² = 25",
          "result": "9x² + 30x + 25",
          "voice_text": "Square a, double the product of a and b, and square b."
        }
      ],
      "trick_id": "T-ALG-001",
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
