    {
      "id": "Q-C8-ALG-002",
      "chapter": "algebraic-expressions-identities",
      "topic": "addition-subtraction",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Add: 5x² − 3x + 4 and 2x² + 7x − 6.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "7x² + 4x − 2",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Group like terms",
          "working": "(5x² + 2x²) + (−3x + 7x) + (4 − 6)",
          "result": "Like terms grouped",
          "voice_text": "Collect terms with the same variable and power together."
        },
        {
          "step_number": 2,
          "instruction": "Add each group",
          "working": "7x² + 4x − 2",
          "result": "7x² + 4x − 2",
          "voice_text": "Add each group separately. The answer is 7x squared plus 4x minus 2."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
