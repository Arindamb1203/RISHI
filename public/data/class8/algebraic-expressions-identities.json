    {
      "id": "Q-C8-ALG-001",
      "chapter": "algebraic-expressions-identities",
      "topic": "types-of-polynomials",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "Which of the following is a binomial?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 3x² + 2x + 1", "B: 5y", "C: 4x² − 7", "D: x + y + z"],
      "correct_answer": "C",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Recall definition of binomial",
          "working": "Binomial = exactly 2 terms. A has 3 terms (trinomial). B has 1 term (monomial). C has 2 terms. D has 3 terms.",
          "result": "C: 4x² − 7",
          "voice_text": "A binomial has exactly two terms. 4x squared minus 7 has two terms — so it is a binomial."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
