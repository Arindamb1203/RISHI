      "correct_answer": "11025",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Write 105 as (100 + 5)",
          "working": "105² = (100 + 5)²",
          "result": "a = 100, b = 5",
          "voice_text": "Express 105 as 100 plus 5 to use the identity."
        },
        {
          "step_number": 2,
          "instruction": "Apply (a + b)² = a² + 2ab + b²",
          "working": "100² + 2×100×5 + 5² = 10000 + 1000 + 25",
          "result": "11025",
          "voice_text": "Apply the identity step by step. 10000 plus 1000 plus 25 equals 11025."
        }
      ],
