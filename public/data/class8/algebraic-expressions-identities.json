    {
      "id": "Q-C8-ALG-011",
      "chapter": "algebraic-expressions-identities",
      "topic": "identity-application",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "If x + 1/x = 5, find the value of x² + 1/x².",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "23",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Square both sides of x + 1/x = 5",
          "working": "(x + 1/x)² = 25",
          "result": "Left side to be expanded",
          "voice_text": "Square both sides. The right side becomes 25."
        },
        {
          "step_number": 2,
          "instruction": "Expand left side using (a+b)² identity",
          "working": "x² + 2(x)(1/x) + 1/x² = 25",
          "result": "x² + 2 + 1/x² = 25",
          "voice_text": "Expand using the identity. Note that x times 1 by x equals 1, so the middle term is 2."
        },
        {
          "step_number": 3,
          "instruction": "Solve for x² + 1/x²",
          "working": "x² + 1/x² = 25 − 2",
          "result": "23",
          "voice_text": "Subtract 2 from both sides. x squared plus 1 by x squared equals 23."
        }
      ],
      "trick_id": null,
      "source": "OLY",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
