    {
      "id": "Q-C8-ALG-004",
      "chapter": "algebraic-expressions-identities",
      "topic": "multiplication",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Multiply: (x + 4)(x − 3).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "x² + x − 12",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use FOIL method",
          "working": "First: x×x = x² | Outer: x×(−3) = −3x | Inner: 4×x = 4x | Last: 4×(−3) = −12",
          "result": "x² − 3x + 4x − 12",
          "voice_text": "Multiply each term in the first bracket with each term in the second bracket."
        },
        {
          "step_number": 2,
          "instruction": "Combine like terms",
          "working": "−3x + 4x = x",
          "result": "x² + x − 12",
          "voice_text": "Combine the middle terms. Negative 3x plus 4x equals x."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
