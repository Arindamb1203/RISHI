    {
      "id": "Q-C8-LIN-005",
      "chapter": "linear-equations",
      "topic": "fractions",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Solve: (x + 3) / 4 = (x − 1) / 2.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "5",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Cross multiply",
          "working": "2(x + 3) = 4(x − 1)",
          "result": "2x + 6 = 4x − 4",
          "voice_text": "Cross multiply — multiply numerator of left by denominator of right, and vice versa."
        },
        {
          "step_number": 2,
          "instruction": "Bring x terms to one side",
          "working": "6 + 4 = 4x − 2x",
          "result": "10 = 2x",
          "voice_text": "Move all x terms to the right and numbers to the left."
        },
        {
          "step_number": 3,
          "instruction": "Solve",
          "working": "x = 10 ÷ 2",
          "result": "x = 5",
          "voice_text": "x equals 5."
        },
        {
          "step_number": 4,
          "instruction": "Verify",
          "working": "LHS = 8/4 = 2 | RHS = 4/2 = 2 ✓",
          "result": "Verified",
          "voice_text": "Both sides equal 2. Correct!"
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
