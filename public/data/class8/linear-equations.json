    {
      "id": "Q-C8-LIN-011",
      "chapter": "linear-equations",
      "topic": "word-problems-geometry",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "The length of a rectangle is 5 cm more than twice its breadth. If the perimeter is 82 cm, find the length and breadth.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Length: 29, Breadth: 12",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Define variables",
          "working": "Let breadth = x cm. Then length = 2x + 5 cm.",
          "result": "Variables defined",
          "voice_text": "Let breadth be x. Length is 5 more than twice the breadth."
        },
        {
          "step_number": 2,
          "instruction": "Use perimeter formula",
          "working": "2(length + breadth) = 82",
          "result": "2(2x + 5 + x) = 82",
          "voice_text": "Perimeter of rectangle equals 2 times the sum of length and breadth."
        },
        {
          "step_number": 3,
          "instruction": "Simplify and solve",
          "working": "2(3x + 5) = 82 → 6x + 10 = 82 → 6x = 72 → x = 12",
          "result": "Breadth = 12 cm",
          "voice_text": "Solve step by step. x equals 12."
        },
        {
          "step_number": 4,
          "instruction": "Find length",
          "working": "Length = 2(12) + 5 = 29 cm",
          "result": "Length = 29 cm",
          "voice_text": "Length is 29 cm. Check: Perimeter = 2 × 41 = 82. Correct!"
        }
      ],
      "trick_id": null,
