    {
      "id": "Q-C8-LIN-002",
      "chapter": "linear-equations",
      "topic": "solving-basic",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "If 3x − 7 = 11, then x equals:",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 4", "B: 5", "C: 6", "D: 7"],
      "correct_answer": "C",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Transpose −7 to the right side",
          "working": "3x = 11 + 7",
          "result": "3x = 18",
          "voice_text": "Move negative 7 to the other side. It becomes positive 7."
        },
        {
          "step_number": 2,
          "instruction": "Divide both sides by 3",
          "working": "x = 18 ÷ 3",
          "result": "x = 6",
          "voice_text": "Divide by 3. x equals 6."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
