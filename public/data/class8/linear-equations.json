    {
      "id": "Q-C8-LIN-012",
      "chapter": "linear-equations",
      "topic": "reducing-equations",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Solve: (3x − 2)/(2x + 3) = (3x − 4)/(2x + 1).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "5",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Cross multiply",
          "working": "(3x − 2)(2x + 1) = (3x − 4)(2x + 3)",
          "result": "Both sides to be expanded",
          "voice_text": "Cross multiply — numerator of left times denominator of right, and vice versa."
        },
        {
          "step_number": 2,
          "instruction": "Expand left side",
          "working": "6x² + 3x − 4x − 2 = 6x² − x − 2",
          "result": "Left = 6x² − x − 2",
          "voice_text": "Multiply every term in the first bracket with every term in the second bracket."
        },
        {
          "step_number": 3,
          "instruction": "Expand right side",
          "working": "6x² + 9x − 8x − 12 = 6x² + x − 12",
          "result": "Right = 6x² + x − 12",
          "voice_text": "Now expand the right side carefully."
        },
        {
          "step_number": 4,
          "instruction": "Subtract 6x² from both sides and solve",
          "working": "−x − 2 = x − 12 → −2x = −10 → x = 5",
          "result": "x = 5",
          "voice_text": "The x squared terms cancel. Collect x terms on one side. x equals 5."
        },
        {
          "step_number": 5,
          "instruction": "Verify",
          "working": "LHS=(15−2)/(10+3)=13/13=1. RHS=(15−4)/(10+1)=11/11=1 ✓",
          "result": "Verified",
          "voice_text": "Both sides equal 1. Correct!"
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
