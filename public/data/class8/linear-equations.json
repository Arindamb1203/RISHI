    {
      "id": "Q-C8-LIN-010",
      "chapter": "linear-equations",
      "topic": "fractions",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Solve: (2x − 1)/3 − (6x − 2)/5 = 1/3.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "-1/2",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find LCM of denominators 3, 5, 3",
          "working": "LCM = 15",
          "result": "Multiply entire equation by 15",
          "voice_text": "To remove fractions, multiply every term by the LCM of all denominators."
        },
        {
          "step_number": 2,
          "instruction": "Multiply through by 15",
          "working": "5(2x − 1) − 3(6x − 2) = 5",
          "result": "10x − 5 − 18x + 6 = 5",
          "voice_text": "Distribute 15 across each term carefully."
        },
        {
          "step_number": 3,
          "instruction": "Simplify left side",
          "working": "−8x + 1 = 5",
          "result": "−8x = 4",
          "voice_text": "Combine like terms on the left side."
        },
        {
          "step_number": 4,
          "instruction": "Solve",
          "working": "x = 4 / −8",
          "result": "x = −1/2",
          "voice_text": "Divide both sides by negative 8. x equals negative one half."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
