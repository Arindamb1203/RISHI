    {
      "id": "Q-C8-LIN-003",
      "chapter": "linear-equations",
      "topic": "solving-basic",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Solve for x: 2x + 5 = 13.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "4",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Transpose 5 to the right side",
          "working": "2x = 13 − 5",
          "result": "2x = 8",
          "voice_text": "Move 5 to the right. When a number crosses the equals sign, its sign changes."
        },
        {
          "step_number": 2,
          "instruction": "Divide both sides by 2",
          "working": "x = 8 ÷ 2",
          "result": "x = 4",
          "voice_text": "Divide both sides by 2. x equals 4."
        },
        {
          "step_number": 3,
          "instruction": "Verify",
          "working": "2(4) + 5 = 8 + 5 = 13 ✓",
          "result": "Verified",
          "voice_text": "Always verify by substituting back into the original equation."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
