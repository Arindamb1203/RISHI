    {
      "id": "Q-C8-LIN-007",
      "chapter": "linear-equations",
      "topic": "word-problems-age",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "Riya is 6 years older than her brother Arjun. Five years from now, the sum of their ages will be 40. Find their present ages.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Riya: 18, Arjun: 12",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Define the variable",
          "working": "Let Arjun's age = x. Then Riya's age = x + 6.",
          "result": "Variables defined",
          "voice_text": "We always start by letting the unknown be x."
        },
        {
          "step_number": 2,
          "instruction": "Write ages 5 years from now",
          "working": "Arjun = x + 5 | Riya = x + 11",
          "result": "Future ages defined",
          "voice_text": "Five years later, add 5 to each current age."
        },
        {
          "step_number": 3,
          "instruction": "Form the equation",
          "working": "(x + 5) + (x + 11) = 40",
          "result": "2x + 16 = 40",
          "voice_text": "Sum of future ages equals 40."
        },
        {
          "step_number": 4,
          "instruction": "Solve",
          "working": "2x = 24, x = 12",
          "result": "Arjun = 12 years",
          "voice_text": "x equals 12. Arjun is 12 years old."
        },
        {
          "step_number": 5,
          "instruction": "Find Riya's age",
          "working": "Riya = 12 + 6 = 18",
          "result": "Riya = 18 years",
          "voice_text": "Riya is 18. Check: 5 years later, 17 + 23 = 40. Correct!"
        }
      ],
      "trick_id": null,
      "source": "RDS",
