    {
      "id": "Q-C8-LIN-009",
      "chapter": "linear-equations",
      "topic": "word-problems-numbers",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "A number is divided into two parts such that one part is 10 more than the other. If the two parts are in the ratio 5:3, find the number.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "40",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Let the smaller part be x",
          "working": "Larger part = x + 10",
          "result": "Two parts defined",
          "voice_text": "Let the smaller part be x. The larger part is 10 more."
        },
        {
          "step_number": 2,
          "instruction": "Use the ratio condition",
          "working": "(x + 10) / x = 5/3",
          "result": "3(x + 10) = 5x",
          "voice_text": "The ratio of larger to smaller is 5 to 3. Cross multiply."
        },
        {
          "step_number": 3,
          "instruction": "Solve",
          "working": "3x + 30 = 5x → 30 = 2x → x = 15",
          "result": "Smaller = 15, Larger = 25",
          "voice_text": "x equals 15. The two parts are 15 and 25."
        },
        {
          "step_number": 4,
          "instruction": "Find the number",
          "working": "15 + 25 = 40",
          "result": "The number is 40",
          "voice_text": "The original number is 40."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
