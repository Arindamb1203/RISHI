    {
      "id": "Q-C8-LIN-008",
      "chapter": "linear-equations",
      "topic": "word-problems-money",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "A shopkeeper sold a shirt for ₹680, making a profit of 36%. Find the cost price.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "500",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Let cost price be x",
          "working": "SP = CP + Profit = x + 36% of x",
          "result": "(136/100)x = 680",
          "voice_text": "We don't know the cost price, so we call it x."
        },
        {
          "step_number": 2,
          "instruction": "Solve for x",
          "working": "x = 680 × 100 / 136",
          "result": "x = 500",
          "voice_text": "Multiply both sides by 100 and divide by 136."
        },
        {
          "step_number": 3,
          "instruction": "Verify",
          "working": "36% of 500 = 180. SP = 500 + 180 = 680 ✓",
          "result": "Verified",
          "voice_text": "Cost price is ₹500. Profit of 36% gives ₹680. Correct!"
        }
      ],
      "trick_id": null,
