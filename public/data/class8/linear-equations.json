    {
      "id": "Q-C8-LIN-006",
      "chapter": "linear-equations",
      "topic": "word-problems-numbers",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The sum of three consecutive even numbers is 78. Find the numbers.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "24, 26, 28",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Define the numbers",
          "working": "Let the numbers be x, x+2, x+4",
          "result": "Consecutive even numbers differ by 2",
          "voice_text": "Consecutive even numbers always have a gap of 2."
        },
        {
          "step_number": 2,
          "instruction": "Form the equation",
          "working": "x + (x+2) + (x+4) = 78",
          "result": "3x + 6 = 78",
          "voice_text": "Add all three and set equal to 78."
        },
        {
          "step_number": 3,
          "instruction": "Solve",
          "working": "3x = 72, x = 24",
          "result": "Numbers are 24, 26, 28",
          "voice_text": "x is 24. The three numbers are 24, 26, and 28."
        }
      ],
      "trick_id": null,
