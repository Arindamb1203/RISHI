          "instruction": "Divide both sides by 4",
          "working": "x + 3 = 28 ÷ 4",
          "result": "x + 3 = 7",
          "voice_text": "Divide both sides by 4 to open the bracket."
        },
        {
          "step_number": 2,
          "instruction": "Transpose 3",
          "working": "x = 7 − 3",
          "result": "x = 4",
          "voice_text": "Move 3 to the right. x equals 4."
        }
      ],
