    {
      "id": "Q-C8-VSS-002",
      "chapter": "visualising-solid-shapes",
      "topic": "euler-formula",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "A polyhedron has 6 faces and 8 vertices. Using Euler's formula, find the number of edges.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "12",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply Euler's formula",
          "working": "F + V − E = 2 → 6 + 8 − E = 2",
          "result": "14 − E = 2",
          "voice_text": "Substitute the known values into Euler's formula."
        },
        {
          "step_number": 2,
          "instruction": "Solve for E",
          "working": "E = 14 − 2 = 12",
          "result": "12 edges",
          "voice_text": "E equals 12. This solid has 12 edges — it is a cuboid."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
