    {
      "id": "Q-C8-VSS-010",
      "chapter": "visualising-solid-shapes",
      "topic": "euler-formula",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A polyhedron has 12 edges and 6 vertices. Find the number of faces. Name the solid if all faces are triangles.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "8 faces — Octahedron",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply Euler's formula",
          "working": "F + V − E = 2 → F + 6 − 12 = 2 → F = 8",
          "result": "8 faces",
          "voice_text": "Using Euler's formula, F plus 6 minus 12 equals 2. So F equals 8."
        },
        {
          "step_number": 2,
          "instruction": "Identify the solid",
          "working": "8 triangular faces, 6 vertices, 12 edges → Regular Octahedron",
          "result": "Octahedron",
          "voice_text": "A polyhedron with 8 triangular faces is a regular octahedron — like two square pyramids joined at the base."
        }
      ],
      "trick_id": null,
