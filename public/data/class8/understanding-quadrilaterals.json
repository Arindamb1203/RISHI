    {
      "id": "Q-C8-QUD-010",
      "chapter": "understanding-quadrilaterals",
      "topic": "exterior-angles",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Each exterior angle of a regular polygon is 40°. How many sides does the polygon have?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "9",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use exterior angle property",
          "working": "Sum of exterior angles of any polygon = 360°",
          "result": "Number of sides = 360 ÷ each exterior angle",
          "voice_text": "The sum of all exterior angles of any polygon is always 360 degrees."
        },
        {
          "step_number": 2,
          "instruction": "Calculate",
          "working": "n = 360 ÷ 40 = 9",
          "result": "9 sides",
          "voice_text": "360 divided by 40 equals 9. The polygon has 9 sides."
        }
      ],
