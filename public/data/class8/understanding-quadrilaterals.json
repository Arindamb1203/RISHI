    {
      "id": "Q-C8-QUD-002",
      "chapter": "understanding-quadrilaterals",
      "topic": "angle-sum",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Three angles of a quadrilateral are 75°, 90° and 110°. Find the fourth angle.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "85",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use angle sum property",
          "working": "Sum of all angles = 360°",
          "result": "Fourth angle = 360 − (75+90+110)",
          "voice_text": "All four angles must add up to 360 degrees."
        },
        {
          "step_number": 2,
          "instruction": "Calculate",
          "working": "75 + 90 + 110 = 275. Fourth angle = 360 − 275 = 85°",
          "result": "85°",
          "voice_text": "360 minus 275 equals 85. The fourth angle is 85 degrees."
        }
      ],
      "trick_id": null,
      "source": "NCT",
