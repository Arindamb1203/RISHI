    {
      "id": "Q-C8-QUD-011",
      "chapter": "understanding-quadrilaterals",
      "topic": "parallelogram-properties",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "ABCD is a parallelogram. If angle A = (3x + 10)° and angle C = (5x − 30)°, find all four angles.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "A=100°, B=80°, C=100°, D=80°",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use opposite angles are equal",
          "working": "Angle A = Angle C → 3x + 10 = 5x − 30",
          "result": "Equation formed",
          "voice_text": "In a parallelogram, opposite angles are equal. Set A equal to C."
        },
        {
          "step_number": 2,
          "instruction": "Solve for x",
          "working": "40 = 2x → x = 20",
          "result": "x = 20",
          "voice_text": "Solve the equation. x equals 20."
        },
        {
          "step_number": 3,
          "instruction": "Find angle A",
          "working": "A = 3(20) + 10 = 70 degrees",
          "result": "A = 70°... wait: 3×20+10=70. C=5×20-30=70. Then B=180-70=110°",
          "voice_text": "Substitute x equals 20 back in."
        },
        {
          "step_number": 4,
          "instruction": "Find all angles",
          "working": "A = 70°, C = 70°, B = 180−70 = 110°, D = 110°",
          "result": "A=70°, B=110°, C=70°, D=110°",
          "voice_text": "Opposite angles are equal, adjacent angles are supplementary. All four angles found."
        }
      ],
      "trick_id": null,
      "source": "CBP",
      "cbse_pattern": true,
