    {
      "id": "Q-C8-QUD-004",
      "chapter": "understanding-quadrilaterals",
      "topic": "parallelogram-properties",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "In a parallelogram ABCD, angle A = 70°. Find angles B, C and D.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "B=110°, C=70°, D=110°",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use co-interior angles property",
          "working": "Adjacent angles in a parallelogram are supplementary. A + B = 180°. B = 180 − 70 = 110°.",
          "result": "B = 110°",
          "voice_text": "Adjacent angles in a parallelogram add up to 180 degrees."
        },
        {
          "step_number": 2,
          "instruction": "Use opposite angles property",
          "working": "Opposite angles are equal. C = A = 70°. D = B = 110°.",
          "result": "C = 70°, D = 110°",
          "voice_text": "Opposite angles in a parallelogram are equal. So C equals A and D equals B."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
