    {
      "id": "Q-C8-QUD-008",
      "chapter": "understanding-quadrilaterals",
      "topic": "angle-sum",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The angles of a quadrilateral are in the ratio 2:3:4:6. Find all the angles.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "48°, 72°, 96°, 144°",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Let angles be 2k, 3k, 4k, 6k",
          "working": "2k + 3k + 4k + 6k = 360",
          "result": "15k = 360",
          "voice_text": "Let the common multiplier be k. Sum all parts and set equal to 360."
        },
        {
          "step_number": 2,
          "instruction": "Solve for k",
          "working": "k = 360 ÷ 15 = 24",
          "result": "k = 24",
          "voice_text": "k equals 24."
        },
        {
          "step_number": 3,
          "instruction": "Find each angle",
          "working": "2×24=48° | 3×24=72° | 4×24=96° | 6×24=144°",
          "result": "48°, 72°, 96°, 144°",
          "voice_text": "Multiply each ratio part by 24. The angles are 48, 72, 96 and 144 degrees."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
