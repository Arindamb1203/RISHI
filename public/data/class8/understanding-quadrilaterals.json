    {
      "id": "Q-C8-QUD-006",
      "chapter": "understanding-quadrilaterals",
      "topic": "rhombus",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The diagonals of a rhombus are 16 cm and 12 cm. Find the side of the rhombus.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "10",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Diagonals of rhombus bisect each other at 90°",
          "working": "Half diagonals = 8 cm and 6 cm",
          "result": "Right triangle with legs 8 and 6",
          "voice_text": "The diagonals of a rhombus bisect each other at right angles, forming right triangles."
        },
        {
          "step_number": 2,
          "instruction": "Apply Pythagoras theorem",
          "working": "Side² = 8² + 6² = 64 + 36 = 100. Side = 10 cm.",
          "result": "10 cm",
          "voice_text": "Use Pythagoras theorem. 8 squared plus 6 squared equals 100. Square root of 100 is 10."
        }
      ],
      "trick_id": null,
