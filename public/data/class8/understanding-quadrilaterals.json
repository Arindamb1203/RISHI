    {
      "id": "Q-C8-QUD-009",
      "chapter": "understanding-quadrilaterals",
      "topic": "polygon-angle-sum",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Find the sum of interior angles of a hexagon.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "720",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply formula for sum of interior angles",
          "working": "Sum = (n − 2) × 180° where n = number of sides",
          "result": "For hexagon, n = 6",
          "voice_text": "The formula for sum of interior angles of a polygon is n minus 2 times 180 degrees."
        },
        {
          "step_number": 2,
          "instruction": "Calculate",
          "working": "(6 − 2) × 180 = 4 × 180 = 720°",
          "result": "720°",
          "voice_text": "4 times 180 equals 720 degrees."
        }
      ],
      "trick_id": null,
