    {
      "id": "Q-C8-QUD-005",
      "chapter": "understanding-quadrilaterals",
      "topic": "parallelogram-properties",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The diagonals of a parallelogram PQRS bisect each other. If PO = 5 cm and QO = 7 cm (O is intersection), find the lengths of both diagonals.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "PR = 10 cm, QS = 14 cm",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Use bisecting property",
          "working": "Diagonals bisect each other → PR = 2 × PO = 2 × 5 = 10 cm",
          "result": "PR = 10 cm",
          "voice_text": "Since diagonals bisect each other, the full diagonal is twice the half."
        },
        {
          "step_number": 2,
          "instruction": "Find QS",
          "working": "QS = 2 × QO = 2 × 7 = 14 cm",
          "result": "QS = 14 cm",
          "voice_text": "Similarly QS equals 14 cm."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
