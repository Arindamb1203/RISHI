    {
      "id": "Q-C8-FAC-001",
      "chapter": "factorisation",
      "topic": "common-factor",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Factorise: 12x² + 18x.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "6x(2x + 3)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find HCF of 12x² and 18x",
          "working": "HCF of 12 and 18 = 6. HCF of x² and x = x. So HCF = 6x.",
          "result": "HCF = 6x",
          "voice_text": "Find the highest common factor of all terms — both the numbers and the variables."
        },
        {
          "step_number": 2,
          "instruction": "Take out the HCF",
          "working": "12x² + 18x = 6x(2x + 3)",
          "result": "6x(2x + 3)",
          "voice_text": "Divide each term by 6x and write the result inside the bracket."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
