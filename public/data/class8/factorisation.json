    {
      "id": "Q-C8-FAC-010",
      "chapter": "factorisation",
      "topic": "regrouping",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Factorise: 2x³ − 3x² − 2x + 3.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "(2x − 3)(x + 1)(x − 1)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Group terms",
          "working": "(2x³ − 3x²) + (−2x + 3)",
          "result": "Two groups",
          "voice_text": "Group first two and last two terms together."
        },
        {
          "step_number": 2,
          "instruction": "Factor each group",
          "working": "x²(2x − 3) − 1(2x − 3)",
          "result": "Common factor (2x−3) visible",
          "voice_text": "Take out x squared from the first group and negative 1 from the second."
        },
        {
          "step_number": 3,
          "instruction": "Factor out (2x − 3)",
          "working": "(2x − 3)(x² − 1)",
          "result": "(2x − 3)(x² − 1)",
          "voice_text": "Take out the common bracket (2x minus 3)."
        },
        {
          "step_number": 4,
          "instruction": "Further factorise x² − 1",
          "working": "x² − 1 = (x+1)(x−1)",
          "result": "(2x − 3)(x + 1)(x − 1)",
          "voice_text": "x squared minus 1 is a difference of squares. Final answer is (2x−3)(x+1)(x−1)."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-FAC-011",
      "chapter": "factorisation",
      "topic": "division-of-polynomials",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Divide: (2x² + 7x + 6) ÷ (x + 2). Verify your answer.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2x + 3",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Factorise the dividend",
          "working": "2x² + 7x + 6: find two numbers with product 2×6=12 and sum 7 → 3 and 4. Split: 2x²+3x+4x+6 = x(2x+3)+2(2x+3) = (2x+3)(x+2)",
          "result": "(2x + 3)(x + 2)",
          "voice_text": "Factorise the numerator first using splitting the middle term."
        },
        {
          "step_number": 2,
          "instruction": "Divide",
          "working": "(2x+3)(x+2) ÷ (x+2) = 2x + 3",
          "result": "Quotient = 2x + 3",
          "voice_text": "Cancel the common factor (x + 2). Quotient is 2x + 3."
        },
        {
          "step_number": 3,
          "instruction": "Verify: Divisor × Quotient = Dividend",
          "working": "(x+2)(2x+3) = 2x²+3x+4x+6 = 2x²+7x+6 ✓",
          "result": "Verified",
          "voice_text": "Multiply quotient by divisor to verify. We get back the original expression. Correct!"
        }
      ],
      "trick_id": null,
      "source": "CBP",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
