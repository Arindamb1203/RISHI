    {
      "id": "Q-C8-FAC-006",
      "chapter": "factorisation",
      "topic": "splitting-middle-term",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Factorise: x² + 7x + 12.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "(x + 3)(x + 4)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find two numbers that multiply to 12 and add to 7",
          "working": "3 × 4 = 12 | 3 + 4 = 7 ✓",
          "result": "Numbers are 3 and 4",
          "voice_text": "We need two numbers whose product is 12 and sum is 7. Those numbers are 3 and 4."
        },
        {
          "step_number": 2,
          "instruction": "Split the middle term",
          "working": "x² + 3x + 4x + 12",
          "result": "Middle term split",
          "voice_text": "Split 7x into 3x and 4x."
        },
        {
          "step_number": 3,
          "instruction": "Group and factor",
          "working": "x(x+3) + 4(x+3) = (x+3)(x+4)",
          "result": "(x + 3)(x + 4)",
          "voice_text": "Group and take out common factors. Answer is (x + 3)(x + 4)."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-FAC-007",
      "chapter": "factorisation",
      "topic": "splitting-middle-term",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Factorise: x² − x − 20.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "(x − 5)(x + 4)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find two numbers: product = −20, sum = −1",
          "working": "−5 × 4 = −20 | −5 + 4 = −1 ✓",
          "result": "Numbers are −5 and 4",
          "voice_text": "We need product negative 20 and sum negative 1. Try negative 5 and positive 4."
        },
        {
          "step_number": 2,
          "instruction": "Split and factor",
          "working": "x² − 5x + 4x − 20 = x(x−5) + 4(x−5)",
          "result": "(x − 5)(x + 4)",
          "voice_text": "Split, group, and factor. Answer is (x − 5)(x + 4)."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": false,
