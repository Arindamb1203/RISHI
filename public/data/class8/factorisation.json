    {
      "id": "Q-C8-FAC-004",
      "chapter": "factorisation",
      "topic": "identity-difference-of-squares",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Factorise: 25x² − 64.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "(5x + 8)(5x − 8)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Recognise as difference of squares",
          "working": "25x² = (5x)² | 64 = 8²",
          "result": "a = 5x, b = 8",
          "voice_text": "Both terms are perfect squares. This matches the identity a squared minus b squared."
        },
        {
          "step_number": 2,
          "instruction": "Apply a² − b² = (a+b)(a−b)",
          "working": "(5x + 8)(5x − 8)",
          "result": "(5x + 8)(5x − 8)",
          "voice_text": "Factorise using the identity. Answer is 5x plus 8 times 5x minus 8."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-FAC-005",
      "chapter": "factorisation",
      "topic": "identity-perfect-square",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Factorise: x² + 10x + 25.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "(x + 5)²",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Check if it is a perfect square trinomial",
          "working": "x² = x² | 25 = 5² | 10x = 2×x×5 ✓",
          "result": "Pattern matches (a+b)²",
          "voice_text": "Check: is the middle term equal to 2 times the square roots of the first and last terms? Yes — 2 times x times 5 equals 10x."
        },
        {
          "step_number": 2,
          "instruction": "Write as perfect square",
          "working": "(x + 5)²",
          "result": "(x + 5)²",
          "voice_text": "The answer is x plus 5, whole squared."
        }
      ],
      "trick_id": null,
      "source": "NCT",
