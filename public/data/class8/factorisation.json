    {
      "id": "Q-C8-FAC-008",
      "chapter": "factorisation",
      "topic": "division-of-polynomials",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Divide: (x² + 7x + 12) ÷ (x + 3).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "x + 4",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Factorise the numerator",
          "working": "x² + 7x + 12 = (x + 3)(x + 4)",
          "result": "Numerator factorised",
          "voice_text": "First factorise the dividend. x squared plus 7x plus 12 equals (x+3)(x+4)."
        },
        {
          "step_number": 2,
          "instruction": "Cancel the common factor",
          "working": "(x+3)(x+4) ÷ (x+3) = x + 4",
          "result": "x + 4",
          "voice_text": "Cancel the common factor (x+3). The quotient is x + 4."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
