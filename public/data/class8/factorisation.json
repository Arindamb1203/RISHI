    {
      "id": "Q-C8-FAC-009",
      "chapter": "factorisation",
      "topic": "division-of-polynomials",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Divide: (8x³ − 12x² + 4x) ÷ 4x.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "2x² − 3x + 1",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Divide each term by 4x",
          "working": "8x³/4x = 2x² | −12x²/4x = −3x | 4x/4x = 1",
          "result": "Each term divided",
          "voice_text": "Divide every term in the numerator by 4x separately."
        },
        {
          "step_number": 2,
          "instruction": "Combine",
          "working": "2x² − 3x + 1",
          "result": "2x² − 3x + 1",
          "voice_text": "The answer is 2x squared minus 3x plus 1."
        }
      ],
      "trick_id": null,
      "source": "RSA",
      "cbse_pattern": true,
