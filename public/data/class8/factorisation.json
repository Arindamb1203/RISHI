    {
      "id": "Q-C8-FAC-003",
      "chapter": "factorisation",
      "topic": "regrouping",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "Factorise by regrouping: ax + bx + ay + by.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "(a + b)(x + y)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Group the terms",
          "working": "(ax + bx) + (ay + by)",
          "result": "Two groups formed",
          "voice_text": "Group the first two terms together and the last two terms together."
        },
        {
          "step_number": 2,
          "instruction": "Factor each group",
          "working": "x(a + b) + y(a + b)",
          "result": "Common factor (a+b) visible",
          "voice_text": "Take out the common factor from each group. Both groups now have (a + b)."
        },
        {
          "step_number": 3,
          "instruction": "Factor out (a + b)",
          "working": "(a + b)(x + y)",
          "result": "(a + b)(x + y)",
          "voice_text": "Take out the common bracket. The answer is (a + b)(x + y)."
        }
      ],
      "trick_id": null,
      "source": "NCT",
