    {
      "id": "Q-C8-FAC-002",
      "chapter": "factorisation",
      "topic": "common-factor",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "Factorise: 15xy − 10x²y + 5xy².",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "5xy(3 − 2x + y)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find HCF of all terms",
          "working": "HCF of 15, 10, 5 = 5. Common variables = xy. HCF = 5xy.",
          "result": "HCF = 5xy",
          "voice_text": "The HCF of the numbers is 5. Both x and y are common to all terms."
        },
        {
          "step_number": 2,
          "instruction": "Factor out 5xy",
          "working": "5xy(3 − 2x + y)",
          "result": "5xy(3 − 2x + y)",
          "voice_text": "Divide each term by 5xy. The result inside the bracket is 3 minus 2x plus y."
        }
      ],
      "trick_id": null,
