      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "A water tank is in the form of a cuboid with length 4 m, breadth 3 m and depth 2.5 m. How many litres does it hold? (1 m³ = 1000 litres)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "30000",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find volume in m³",
          "working": "V = 4 × 3 × 2.5 = 30 m³",
          "result": "30 m³",
          "voice_text": "Volume equals 4 times 3 times 2.5 = 30 cubic metres."
        },
        {
          "step_number": 2,
          "instruction": "Convert to litres",
          "working": "30 × 1000 = 30000 litres",
          "result": "30000 litres",
          "voice_text": "1 cubic metre equals 1000 litres. So 30 cubic metres equals 30000 litres."
        }
      ],
      "trick_id": null,
      "source": "NCT",
