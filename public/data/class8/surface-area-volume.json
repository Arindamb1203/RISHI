      "diagram_description": null,
      "options": null,
      "correct_answer": "184",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply TSA formula",
          "working": "TSA = 2(lb + bh + lh) = 2(8×5 + 5×4 + 8×4)",
          "result": "= 2(40 + 20 + 32)",
          "voice_text": "Substitute l=8, b=5, h=4 into the formula."
        },
        {
          "step_number": 2,
          "instruction": "Calculate",
          "working": "= 2 × 92 = 184 cm²",
          "result": "184 cm²",
          "voice_text": "2 times 92 equals 184 square centimetres."
        }
      ],
      "trick_id": null,
