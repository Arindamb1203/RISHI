      "times_wrong": 0
    },

    {
      "id": "Q-C8-SAV-011",
      "chapter": "surface-area-volume",
      "topic": "cylinder-volume",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A cylindrical well has diameter 1.4 m and depth 10 m. Find the volume of earth dug out. If this earth is spread uniformly over a rectangular field 14 m × 11 m, find the height of the platform formed. (π = 22/7)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Volume=15.4 m³, Height=0.1 m",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find radius",
          "working": "Diameter = 1.4 m → radius = 0.7 m",
          "result": "r = 0.7 m",
          "voice_text": "Radius is half of diameter. 1.4 divided by 2 equals 0.7 m."
        },
        {
          "step_number": 2,
          "instruction": "Volume of well",
          "working": "V = πr²h = (22/7) × 0.7² × 10 = (22/7) × 0.49 × 10 = 22 × 0.07 × 10 = 15.4 m³",
          "result": "15.4 m³",
          "voice_text": "Volume of the cylindrical well is 15.4 cubic metres."
        },
        {
          "step_number": 3,
          "instruction": "Height of platform",
          "working": "Volume = Area × Height → 15.4 = 14 × 11 × h = 154h → h = 0.1 m",
          "result": "h = 0.1 m",
          "voice_text": "Divide the volume by the field area. 15.4 divided by 154 equals 0.1 m."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-SAV-012",
      "chapter": "surface-area-volume",
      "topic": "cube-volume",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A cube of edge 10 cm is cut into smaller cubes each of edge 2 cm. Find: (i) number of smaller cubes, (ii) total surface area of all smaller cubes combined.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "125 cubes, 3000 cm²",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Find number of smaller cubes",
          "working": "Volume of large cube = 10³ = 1000 cm³ | Volume of small cube = 2³ = 8 cm³ | Number = 1000 ÷ 8 = 125",
          "result": "125 cubes",
          "voice_text": "Divide the volume of the large cube by the volume of one small cube. 1000 divided by 8 equals 125."
        },
        {
          "step_number": 2,
          "instruction": "TSA of one small cube",
          "working": "TSA = 6 × 2² = 6 × 4 = 24 cm²",
          "result": "24 cm²",
          "voice_text": "Each small cube has total surface area of 6 times 4 = 24 square centimetres."
        },
        {
          "step_number": 3,
          "instruction": "Total TSA of all cubes",
          "working": "125 × 24 = 3000 cm²",
          "result": "3000 cm²",
          "voice_text": "Total surface area of all 125 cubes is 125 times 24 = 3000 square centimetres."
        }
      ],
      "trick_id": null,
      "source": "OLY",
      "cbse_pattern": true,
      "exam_exclusive": true,
