    {
      "id": "Q-C8-SAV-009",
      "chapter": "surface-area-volume",
      "topic": "cylinder-surface-area",
      "type": "LONG",
      "difficulty": "medium",
      "marks": 3,
      "question_text": "Find the total surface area of a cylinder with radius 3.5 cm and height 10 cm. (π = 22/7)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "297",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply TSA formula for cylinder",
          "working": "TSA = 2πr(r + h) = 2 × (22/7) × 3.5 × (3.5 + 10)",
          "result": "= 2 × 22/7 × 3.5 × 13.5",
          "voice_text": "Total surface area of cylinder is 2 pi r times r plus h."
        },
        {
          "step_number": 2,
          "instruction": "Calculate",
          "working": "= 2 × 22 × 0.5 × 13.5 = 22 × 13.5 = 297 cm²",
          "result": "297 cm²",
          "voice_text": "Working through the multiplication gives 297 square centimetres."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
