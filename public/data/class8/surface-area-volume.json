    {
      "id": "Q-C8-SAV-010",
      "chapter": "surface-area-volume",
      "topic": "cuboid-surface-area",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A room is 8 m long, 6 m wide and 3 m high. Find the cost of painting its 4 walls and ceiling at ₹25 per m². (No door/window deduction)",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "3300",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Area of 4 walls (lateral surface area)",
          "working": "LSA = 2h(l + b) = 2 × 3 × (8 + 6) = 2 × 3 × 14 = 84 m²",
          "result": "84 m²",
          "voice_text": "Lateral surface area is 2 times height times sum of length and breadth."
        },
        {
          "step_number": 2,
          "instruction": "Area of ceiling",
          "working": "Ceiling = l × b = 8 × 6 = 48 m²",
          "result": "48 m²",
          "voice_text": "Ceiling area is length times breadth."
        },
        {
          "step_number": 3,
          "instruction": "Total area to paint",
          "working": "84 + 48 = 132 m²",
          "result": "132 m²",
          "voice_text": "Add walls and ceiling. Total area is 132 square metres."
        },
        {
          "step_number": 4,
          "instruction": "Calculate cost",
          "working": "132 × 25 = ₹3300",
          "result": "₹3300",
          "voice_text": "Cost equals area times rate. 132 times 25 equals ₹3300."
        }
      ],
      "trick_id": null,
      "source": "CBP",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
