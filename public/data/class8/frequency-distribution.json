    {
      "id": "Q-C8-FRQ-003",
      "chapter": "frequency-distribution",
      "topic": "tally-frequency",
      "type": "SHORT",
      "difficulty": "easy",
      "marks": 2,
      "question_text": "The marks of 10 students are: 45, 62, 78, 45, 90, 62, 78, 45, 62, 90. Make a frequency table.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "45:3, 62:3, 78:2, 90:2",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "List all unique values",
          "working": "45, 62, 78, 90",
          "result": "4 unique values",
          "voice_text": "First list all different values that appear in the data."
        },
        {
          "step_number": 2,
          "instruction": "Count each value",
          "working": "45 → 3 times | 62 → 3 times | 78 → 2 times | 90 → 2 times",
          "result": "Frequencies noted",
          "voice_text": "Count how many times each value appears. This is the frequency."
        },
        {
          "step_number": 3,
          "instruction": "Verify total",
          "working": "3 + 3 + 2 + 2 = 10 ✓",
          "result": "Total matches",
          "voice_text": "Always check that all frequencies add up to the total number of values."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-FRQ-004",
      "chapter": "frequency-distribution",
      "topic": "grouped-frequency",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "In a grouped frequency distribution, the difference between the upper and lower limits of a class interval is called:",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: Class mark", "B: Class width", "C: Frequency", "D: Range"],
      "correct_answer": "B",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Recall definition",
          "working": "Upper limit − Lower limit = Class width (also called class size)",
          "result": "Class width",
          "voice_text": "The difference between upper and lower class limits is the class width or class size."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
