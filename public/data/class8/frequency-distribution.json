    {
      "id": "Q-C8-FRQ-009",
      "chapter": "frequency-distribution",
      "topic": "pie-chart",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "In a survey, 200 students chose their favourite subject: Maths 60, Science 50, English 40, Hindi 30, Social Science 20. Find the central angle for each subject in a pie chart.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Maths:108°, Science:90°, English:72°, Hindi:54°, Social:36°",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Formula for central angle",
          "working": "Angle = (Frequency / Total) × 360°",
          "result": "Formula noted",
          "voice_text": "To find the angle for each sector, divide its frequency by the total and multiply by 360 degrees."
        },
        {
          "step_number": 2,
          "instruction": "Calculate each angle",
          "working": "Maths: 60/200 × 360 = 108° | Science: 50/200 × 360 = 90° | English: 40/200 × 360 = 72° | Hindi: 30/200 × 360 = 54° | Social: 20/200 × 360 = 36°",
          "result": "All angles calculated",
          "voice_text": "Divide each count by 200 and multiply by 360."
        },
        {
          "step_number": 3,
          "instruction": "Verify total",
          "working": "108 + 90 + 72 + 54 + 36 = 360° ✓",
          "result": "Total = 360°. Correct.",
          "voice_text": "All angles must add up to 360 degrees. They do. Our answers are correct."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
