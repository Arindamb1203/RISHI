    {
      "id": "Q-C8-FRQ-005",
      "chapter": "frequency-distribution",
      "topic": "grouped-frequency",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The weights (in kg) of 12 students are: 35, 42, 48, 35, 50, 42, 60, 48, 35, 55, 60, 42. Prepare a frequency table and find which weight appears most often.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "35 and 42 (both appear 3 times)",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Tally the weights",
          "working": "35→3 | 42→3 | 48→2 | 50→1 | 55→1 | 60→2",
          "result": "Frequency table complete",
          "voice_text": "Go through each value and tally it up."
        },
        {
          "step_number": 2,
          "instruction": "Verify total",
          "working": "3+3+2+1+1+2 = 12 ✓",
          "result": "Total matches",
          "voice_text": "All frequencies add to 12. Correct."
        },
        {
          "step_number": 3,
          "instruction": "Find highest frequency",
          "working": "35 and 42 both have frequency 3 — the highest",
          "result": "35 kg and 42 kg both appear most often",
          "voice_text": "Both 35 and 42 appear 3 times — the highest frequency. They are both the mode."
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
