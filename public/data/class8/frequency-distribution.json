        {
          "step_number": 1,
          "instruction": "Count how many times 20 appears",
          "working": "10, 20✓, 10, 30, 20✓, 10, 40, 20✓ — three times",
          "result": "Frequency of 20 = 3",
          "voice_text": "Go through the data and count each time 20 appears. It appears 3 times."
        }
      ],
      "trick_id": null,
      "source": "NCT",
