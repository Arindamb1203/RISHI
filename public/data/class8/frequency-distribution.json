      "chapter": "frequency-distribution",
      "topic": "tally-frequency",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "The marks scored by 8 students are: 10, 20, 10, 30, 20, 10, 40, 20. What is the frequency of the marks 20?",
