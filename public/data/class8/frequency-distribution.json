    {
      "id": "Q-C8-FRQ-006",
      "chapter": "frequency-distribution",
      "topic": "grouped-frequency",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "In a class interval 20-30, what is the class mark?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "25",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply class mark formula",
          "working": "Class mark = (Lower limit + Upper limit) / 2 = (20 + 30) / 2",
          "result": "= 25",
          "voice_text": "Class mark is the midpoint of the class interval. Add the two limits and divide by 2."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
