    {
      "id": "Q-C8-PWR-009",
      "chapter": "powers-exponents",
      "topic": "laws-of-exponents",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Simplify and express with positive exponents: (2⁻³ × 3² × 4) / (3⁻¹ × 2⁴).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "27/32",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Express 4 as power of 2",
          "working": "4 = 2². Numerator: 2⁻³ × 3² × 2² = 2⁻¹ × 3²",
          "result": "Numerator = 2⁻¹ × 3²",
          "voice_text": "Replace 4 with 2 squared. Then combine powers of 2 in the numerator."
        },
        {
          "step_number": 2,
          "instruction": "Write complete expression",
          "working": "(2⁻¹ × 3²) / (3⁻¹ × 2⁴) = 2⁻¹⁻⁴ × 3²⁻⁽⁻¹⁾ = 2⁻⁵ × 3³",
          "result": "2⁻⁵ × 3³",
          "voice_text": "Subtract exponents. For 2: -1 minus 4 = -5. For 3: 2 minus -1 = 3."
        },
        {
          "step_number": 3,
          "instruction": "Convert to positive exponents",
          "working": "3³/2⁵ = 27/32",
          "result": "27/32",
          "voice_text": "Move 2 to the denominator to make the exponent positive. Answer is 27 by 32."
        }
      ],
      "trick_id": null,
      "source": "EXM",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
