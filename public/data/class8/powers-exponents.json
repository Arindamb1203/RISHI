      "chapter": "powers-exponents",
      "topic": "laws-of-exponents",
      "type": "MCQ",
      "difficulty": "easy",
      "marks": 1,
      "question_text": "What is the value of 2⁻³?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: −8", "B: 8", "C: 1/8", "D: −1/8"],
      "correct_answer": "C",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply negative exponent rule",
          "working": "a⁻ⁿ = 1/aⁿ → 2⁻³ = 1/2³ = 1/8",
          "result": "1/8",
          "voice_text": "A negative exponent means take the reciprocal. 2 to the power negative 3 equals 1 by 8."
        }
      ],
      "trick_id": null,
      "source": "NCT",
