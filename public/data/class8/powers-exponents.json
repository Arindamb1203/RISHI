    {
      "id": "Q-C8-PWR-010",
      "chapter": "powers-exponents",
      "topic": "standard-form",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "The distance from Earth to the Sun is approximately 149,600,000 km. Express this in standard form. If light travels at 3 × 10⁵ km/s, how many seconds does light take to reach Earth from the Sun?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "1.496 × 10⁸ km, approximately 499 seconds",
      "answer_tolerance": 5,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Convert to standard form",
          "working": "149600000 = 1.496 × 10⁸ km",
          "result": "1.496 × 10⁸ km",
          "voice_text": "Move the decimal after the first significant digit. 149600000 becomes 1.496 times 10 to the 8."
        },
        {
          "step_number": 2,
          "instruction": "Time = Distance / Speed",
          "working": "t = (1.496 × 10⁸) / (3 × 10⁵) = (1.496/3) × 10³ ≈ 0.499 × 10³",
          "result": "≈ 499 seconds",
          "voice_text": "Divide distance by speed. 1.496 divided by 3 is approximately 0.499. Times 10 cubed gives about 499 seconds."
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-PWR-011",
      "chapter": "powers-exponents",
      "topic": "laws-of-exponents",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Find x if: (3/2)ˣ⁺¹ × (2/3)⁵ = (2/3).",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "3",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Convert all to same base fraction",
          "working": "(3/2)ˣ⁺¹ = (2/3)⁻⁽ˣ⁺¹⁾. So: (2/3)⁻⁽ˣ⁺¹⁾ × (2/3)⁵ = (2/3)¹",
          "result": "All in base (2/3)",
          "voice_text": "Convert 3 by 2 to 2 by 3 with negative exponent. Now all terms have the same base."
        },
        {
          "step_number": 2,
          "instruction": "Add exponents on left side",
          "working": "(2/3)^[−(x+1)+5] = (2/3)¹",
          "result": "−x − 1 + 5 = 1",
          "voice_text": "Same bases on both sides, so equate exponents."
        },
        {
          "step_number": 3,
          "instruction": "Solve for x",
          "working": "−x + 4 = 1 → −x = −3 → x = 3",
          "result": "x = 3",
          "voice_text": "Solve the equation. x equals 3."
        }
      ],
      "trick_id": null,
