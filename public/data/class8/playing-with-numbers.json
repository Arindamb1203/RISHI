      "difficulty": "easy",
      "marks": 1,
      "question_text": "Which of the following is divisible by 9?",
      "diagram_needed": false,
      "diagram_description": null,
      "options": ["A: 12345", "B: 45678", "C: 36251", "D: 72819"],
      "correct_answer": "D",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Apply divisibility rule for 9 — sum of digits must be divisible by 9",
          "working": "A: 1+2+3+4+5=15 (not div by 9) ✗ | B: 4+5+6+7+8=30 (not div by 9) ✗ | C: 3+6+2+5+1=17 (not div by 9) ✗ | D: 7+2+8+1+9=27 (27÷9=3) ✓",
          "result": "D: 72819",
          "voice_text": "Add the digits of each option. The one whose digit sum is divisible by 9 is the answer. Only 72819 gives a digit sum of 27."
        }
      ],
      "trick_id": null,
      "source": "NCT",
