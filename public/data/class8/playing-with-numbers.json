    {
      "id": "Q-C8-PLY-009",
      "chapter": "playing-with-numbers",
      "topic": "number-puzzles",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "A number is 5 times the sum of its digits. If 9 is added to the number, the digits interchange. Find the number.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "45",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Let number be 10a + b",
          "working": "Condition 1: 10a + b = 5(a + b) → 10a + b = 5a + 5b → 5a = 4b",
          "result": "5a = 4b",
          "voice_text": "The number is 5 times the sum of its digits. This gives 5a equals 4b."
        },
        {
          "step_number": 2,
          "instruction": "Apply second condition",
          "working": "(10a + b) + 9 = 10b + a → 9a − 9b = −9 → b − a = 1",
          "result": "b = a + 1",
          "voice_text": "Adding 9 interchanges the digits. This gives b minus a equals 1."
        },
        {
          "step_number": 3,
          "instruction": "Solve simultaneously",
          "working": "5a = 4(a+1) → 5a = 4a + 4 → a = 4. Then b = 5.",
          "result": "a = 4, b = 5",
          "voice_text": "Substituting, a equals 4 and b equals 5."
        },
        {
          "step_number": 4,
          "instruction": "State the number",
          "working": "Number = 10(4) + 5 = 45. Verify: 5×(4+5) = 45 ✓. 45+9=54 (digits reversed) ✓",
          "result": "45",
          "voice_text": "The number is 45. Check: 5 times 9 is 45. And 45 plus 9 is 54, which is 45 reversed. Correct!"
        }
      ],
      "trick_id": null,
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
    },

    {
      "id": "Q-C8-PLY-010",
      "chapter": "playing-with-numbers",
      "topic": "number-forms",
      "type": "LONG",
      "difficulty": "hard",
      "marks": 4,
      "question_text": "Show that the difference of a 3-digit number of the form ABB and its reverse BBA is always a multiple of 99. Verify with 522 − 225.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Proven algebraically; 522 − 225 = 297 = 3×99",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Write 3-digit number ABB in expanded form",
          "working": "ABB = 100A + 10B + B = 100A + 11B",
          "result": "100A + 11B",
          "voice_text": "Express the number algebraically using place values."
        },
        {
          "step_number": 2,
          "instruction": "Write reverse BBA",
          "working": "BBA = 100B + 10B + A = 110B + A",
          "result": "110B + A",
          "voice_text": "The reversed number BBA has hundreds digit B, tens digit B, and units digit A."
        },
        {
          "step_number": 3,
          "instruction": "Subtract",
          "working": "(100A + 11B) − (110B + A) = 99A − 99B = 99(A − B)",
          "result": "99(A − B)",
          "voice_text": "The difference is 99 times A minus B. This is always a multiple of 99."
        },
        {
          "step_number": 4,
          "instruction": "Verify with 522 − 225",
          "working": "A=5, B=2. 522−225=297=99×3=99×(5−2) ✓",
          "result": "297 = 99 × 3",
          "voice_text": "522 minus 225 is 297. And 99 times 3 is also 297. Verified!"
        }
      ],
      "trick_id": "T-PLY-002",
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": true,
      "verified": true,
      "year_last_used": null,
