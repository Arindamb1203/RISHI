    {
      "id": "Q-C8-PLY-006",
      "chapter": "playing-with-numbers",
      "topic": "reversing-digits",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "The sum of a 2-digit number and the number formed by reversing its digits is 110. If the tens digit is greater than the units digit by 4, find the number.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "73",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Let number be 10a + b",
          "working": "Reversed number = 10b + a. Sum = (10a+b)+(10b+a) = 11(a+b) = 110 → a + b = 10",
          "result": "a + b = 10",
          "voice_text": "The sum of a number and its reverse is always 11 times the sum of its digits. 11 times (a+b) equals 110, so a plus b equals 10."
        },
        {
          "step_number": 2,
          "instruction": "Use second condition",
          "working": "a − b = 4",
          "result": "a − b = 4",
          "voice_text": "The tens digit is greater than the units digit by 4."
        },
        {
          "step_number": 3,
          "instruction": "Solve simultaneously",
          "working": "Adding: 2a = 14 → a = 7. Then b = 3.",
          "result": "a = 7, b = 3",
          "voice_text": "Add the two equations. 2a equals 14, so a equals 7 and b equals 3."
        },
        {
          "step_number": 4,
          "instruction": "State the number and verify",
          "working": "Number = 73. Reversed = 37. Sum = 73+37=110 ✓. Difference of digits = 7−3=4 ✓",
          "result": "73",
          "voice_text": "The number is 73. Check: 73 plus 37 equals 110. Tens digit minus units digit is 4. Correct!"
        }
      ],
      "trick_id": null,
      "source": "RDS",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
      "year_last_used": null,
      "rested": false,
      "times_served": 0,
      "times_correct": 0,
      "times_wrong": 0
