    {
      "id": "Q-C8-PLY-007",
      "chapter": "playing-with-numbers",
      "topic": "number-forms",
      "type": "SHORT",
      "difficulty": "medium",
      "marks": 2,
      "question_text": "If the digits of a 2-digit number are a and b, show that the sum of the number and its reverse is always divisible by 11.",
      "diagram_needed": false,
      "diagram_description": null,
      "options": null,
      "correct_answer": "Always divisible by 11",
      "answer_tolerance": 0,
      "solution_steps": [
        {
          "step_number": 1,
          "instruction": "Write the number and its reverse",
          "working": "Number = 10a + b. Reversed = 10b + a.",
          "result": "Both expressions written",
          "voice_text": "The original number is 10a plus b. Reversing digits gives 10b plus a."
        },
        {
          "step_number": 2,
          "instruction": "Add them",
          "working": "(10a + b) + (10b + a) = 11a + 11b = 11(a + b)",
          "result": "11(a + b)",
          "voice_text": "Adding them gives 11a plus 11b, which is 11 times a plus b. Clearly divisible by 11."
        }
      ],
      "trick_id": "T-PLY-001",
      "source": "NCT",
      "cbse_pattern": true,
      "exam_exclusive": false,
      "verified": true,
